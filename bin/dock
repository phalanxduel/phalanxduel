#!/usr/bin/env sh
# bin/dock — TASK-170
#
# Runs an arbitrary command inside the 'automation' service container.
# Ensures the 'dev' profile is active and removes the container after exit.
#
# Usage:
#   bin/dock pnpm test
#   bin/dock pnpm verify:full
#   bin/dock bash
#

set -eu

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  echo "Usage: bin/dock <command>"
  echo ""
  echo "Runs an arbitrary command inside the 'automation' service container."
  echo "Ensures the 'dev' profile is active and removes the container after exit."
  echo ""
  echo "Examples:"
  echo "  bin/dock pnpm test"
  echo "  bin/dock bash"
  exit 0
fi

# Ensure we are in the repo root
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

# Check if docker is running
if ! docker info >/dev/null 2>&1; then
  echo "❌ Docker is not running. Please start Colima or Docker Desktop."
  exit 1
fi

# Run the command with rtk prefix if available (passed through if not)
# We use --rm to keep the host clean.
# We use --profile dev to ensure the automation service is available.
exec rtk docker-compose --profile dev run --rm automation "$@"
