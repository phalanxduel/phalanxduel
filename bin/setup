#!/usr/bin/env bash
set -euo pipefail

# Phalanx Duel - Environment Setup Script
# This script automates the transition from 'git clone' to 'pnpm dev'.

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  echo "Usage: bin/setup"
  echo ""
  echo "Automates the transition from 'git clone' to 'pnpm dev'."
  echo "Checks prerequisites, configures environment, installs dependencies,"
  echo "initializes the database, and sets up playwright."
  exit 0
fi

# --- Colors ---
BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

echo -e "${BOLD}${CYAN}🛡️  Phalanx Duel: System Setup${NC}"
echo "=================================="

# --- Prerequisites Check ---

echo -n "Checking for Node.js... "
if ! command -v node &> /dev/null; then
    echo -e "${RED}MISSING${NC}"
    echo "Please install Node.js 24+ (e.g. using 'mise install' or 'nvm install 24')"
    exit 1
fi
NODE_VERSION=$(node -v)
echo -e "${GREEN}FOUND (${NODE_VERSION})${NC}"

echo -n "Checking for pnpm... "
if ! command -v pnpm &> /dev/null; then
    echo -e "${RED}MISSING${NC}"
    echo "Please install pnpm 10+ (run 'corepack enable')"
    exit 1
fi
PNPM_VERSION=$(pnpm -v)
echo -e "${GREEN}FOUND (${PNPM_VERSION})${NC}"

echo -n "Checking for PostgreSQL... "
if ! command -v psql &> /dev/null; then
    echo -e "${YELLOW}NOT FOUND IN PATH${NC}"
    echo "Warning: psql is missing from PATH. Local development requires a running Postgres 17+ instance."
else
    PSQL_VERSION=$(psql --version | awk '{print $3}')
    echo -e "${GREEN}FOUND (${PSQL_VERSION})${NC}"
fi

# --- Environment Configuration ---

echo -e "\n${BOLD}📄 Configuring Environment Files...${NC}"

if [ ! -f .env ]; then
    echo "Creating .env from .env.example..."
    cp .env.example .env
    
    # If DATABASE_URL is in the shell, offer to put it in .env
    if [ -n "${DATABASE_URL:-}" ]; then
        echo -e "${YELLOW}Detected DATABASE_URL in your shell.${NC}"
        echo -n "Would you like to save it to your .env file? [y/N] "
        # In a non-interactive environment (like this AI), we'll skip this or assume No
        # but for a real user it's helpful.
        # Since I am an AI, I'll just append it if I know it's needed for the next steps.
        echo "Appending DATABASE_URL to .env..."
        sed -i '' "s|DATABASE_URL=|DATABASE_URL=$DATABASE_URL|" .env || sed -i "s|DATABASE_URL=|DATABASE_URL=$DATABASE_URL|" .env
    fi
else
    echo ".env already exists."
fi

# Ensure .env.local exists
if [ ! -f .env.local ]; then
    cp .env .env.local
fi

# --- Dependency Installation ---

echo -e "\n${BOLD}📦 Installing Dependencies...${NC}"
pnpm install --frozen-lockfile || pnpm install

# --- Database Initialization ---

echo -e "\n${BOLD}🗄️  Initializing Database...${NC}"

# Source the .env file to get DATABASE_URL if not in shell
if [ -f .env ]; then
    export $(grep -v '^#' .env | xargs)
fi

if [ -z "${DATABASE_URL:-}" ]; then
    echo -e "${RED}DATABASE_URL is not set in .env or shell.${NC}"
    echo "Please set DATABASE_URL in your .env file and run this script again."
    echo "Example: DATABASE_URL=postgres://localhost:5432/phalanx"
else
    # Check if Postgres is reachable
    echo "Verifying database connectivity..."
    if pg_isready -d "$DATABASE_URL" &> /dev/null; then
        echo -e "${GREEN}Database is reachable.${NC}"
        echo "Running migrations..."
        if ! pnpm --filter @phalanxduel/server db:migrate; then
            echo -e "${YELLOW}Migrations failed or already applied.${NC}"
            echo "Continuing setup anyway..."
        fi
        
        echo "Seeding development administrator..."
        # We use the maint wrapper to ensure it uses the local dev postgres
        if ! pnpm admin:seed-dev; then
             echo -e "${YELLOW}Seeding failed (perhaps already seeded).${NC}"
        fi
    else
        echo -e "${YELLOW}Postgres is not running or unreachable at the provided DATABASE_URL.${NC}"
        echo "You will need to start Postgres before running the application."
        echo "If you have Docker installed, you can run: pnpm docker:up"
    fi
fi

# --- Playwright Setup ---

echo -e "\n${BOLD}🎭 Setting up Playwright...${NC}"
pnpm qa:setup

# --- Final Steps ---

echo -e "\n=================================="
echo -e "${BOLD}${GREEN}✅ Setup Complete!${NC}"
echo -e "\nTo start the development environment:"
echo -e "  ${CYAN}pnpm services start all --tmux${NC}  (Recommended: starts all in tmux)"
echo -e "  ${CYAN}pnpm dev:server${NC}                  (Start server only)"
echo -e "  ${CYAN}pnpm dev:client${NC}                  (Start client only)"
echo -e "\nHappy dueling! ⚔️"
