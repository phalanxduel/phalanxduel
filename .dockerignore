# ── Dependencies ──────────────────────────────────────────────────────
# Installed fresh by Dockerfile stages; no need to include in build context
node_modules
*/node_modules
**/node_modules

# ── Build artifacts ───────────────────────────────────────────────────
# Rebuilt by Dockerfile; exclude to improve build context size and cache hits
# NOTE: dist/ IS NEEDED during build stage; only excluded from runtime layer
# dist
# */dist

# ── Development files ──────────────────────────────────────────────────
# Test files, coverage reports, dev-only artifacts; not needed in container
*.test.ts
*.spec.ts
.vitest
.playwright
coverage
.nyc_output
tmp
artifacts
logs

# ── Documentation ──────────────────────────────────────────────────────
# Large docs not needed in container
docs
docs/api
docs/dash
backlog
AGENTS.md
CHANGELOG.md
GLOSSARY.md

# ── Configuration & secrets ────────────────────────────────────────────
# Environment files (never in image), git metadata, editor config
.env
.env.*
!.env.example
.git
.gitignore
.github/
.husky/
.vscode/
.idea/
*.log

# ── Metadata & licenses ────────────────────────────────────────────────
# Large files not needed in container
LICENSE
LICENSE-ASSETS
COPYING

# ── Operating system ──────────────────────────────────────────────────
.DS_Store
.Thumbs.db
