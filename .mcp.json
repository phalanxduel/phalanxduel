{
  "mcpServers": {
    "phalanx-local": {
      "type": "stdio",
      "command": "node",
      "args": ["--import", "tsx/esm", "/Users/mike/github.com/phalanxduel/game/mcp/src/server.ts"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "TOOL_PROFILE": "admin",
        "APP_ENV": "local",
        "ANALYSIS_PROVIDER": "llama",
        "LLAMA_BASE_URL": "http://127.0.0.1:8080/v1",
        "LLAMA_MODEL": "local",
        "GAME_SERVER_URL": "http://127.0.0.1:3001",
        "AGENT_TOKEN": "${AGENT_TOKEN}"
      }
    },
    "phalanx-prod-public": {
      "type": "http",
      "url": "https://phalanxduel-mcp-public.fly.dev/mcp"
    },
    "phalanx-staging-public": {
      "type": "http",
      "url": "https://phalanxduel-mcp-public-staging.fly.dev/mcp"
    },
    "phalanx-prod-admin": {
      "type": "http",
      "url": "http://127.0.0.1:8081/mcp",
      "headers": {
        "Authorization": "Bearer ${MCP_ADMIN_TOKEN}"
      }
    }
  }
}
