# Phalanx Duel - Shared Defaults
# This file is committed. Do NOT put secrets here.
# Use .env.local for local secrets.

APP_ENV=local
NODE_ENV=development

# Application Ports
PHALANX_SERVER_PORT=3001
PHALANX_ADMIN_PORT=3002
PHALANX_CLIENT_PORT=5173

# Common Defaults
HOST=0.0.0.0
LOG_LEVEL=debug

# Observability  Defaults
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4320
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
