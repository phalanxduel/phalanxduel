flowchart LR
  CLIENT[Browser or external client] --> ROOT["/ static SPA"]
  CLIENT --> DOCS["/docs Swagger UI"]
  CLIENT --> OPENAPI["/docs/json OpenAPI"]
  CLIENT --> ADMIN["/admin Basic Auth HTML"]
  CLIENT --> HEALTH["/health JSON"]
  CLIENT --> DEFAULTS["/api/defaults JSON"]
  CLIENT --> MATCHES["/matches feed JSON"]
  CLIENT --> CREATE["POST /matches"]
  CLIENT --> LOBBY["GET /api/matches/lobby"]
  CLIENT --> JOIN["POST /api/matches/:id/join"]
  CLIENT --> REPLAY["/matches/:id/replay Basic Auth JSON"]
  CLIENT --> WS["/ws WebSocket"]
  WS --> WS_MSG["createMatch / joinMatch / rejoinMatch / watchMatch / action"]
  WS --> WS_RELIABILITY["ack / ping / pong / msgId replay"]
