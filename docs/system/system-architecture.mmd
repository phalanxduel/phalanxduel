    Server --> Shared
    Server -->|"Drizzle ORM"| DB
    Server -->|"OTLP"| OTEL

    MCPHttp --> Engine
    MCPHttp --> Shared
    MCPHttp -.->|"DATABASE_URL\n(optional)"| DB
    MCPHttp -.->|"GAME_SERVER_URL\n(gameplay tier)"| Server

    MCPStdio --> Engine
    MCPStdio --> Shared
    MCPStdio -.->|"optional"| DB
    MCPStdio -.->|"optional"| Server

    Docker -->|"HTTP + WebSocket"| Server

