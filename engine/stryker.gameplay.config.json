{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.schema.json",
  "mutate": ["src/liveness.ts", "src/combat-math.ts"],
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["progress", "clear-text"],
  "mutator": {
    "excludedMutations": [
      "ArrayDeclaration",
      "ArrowFunction",
      "BlockStatement",
      "ObjectLiteral",
      "StringLiteral"
    ]
  },
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "ignoreStatic": true,
  "incremental": false,
  "concurrency": 2,
  "thresholds": {
    "high": 95,
    "low": 90,
    "break": 90
  }
}
