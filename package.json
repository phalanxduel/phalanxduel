{
  "name": "@phalanxduel/root",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter @phalanxduel/shared test:coverage && pnpm --filter @phalanxduel/engine test:coverage && pnpm --filter @phalanxduel/server test:coverage && pnpm coverage:report",
    "test:engine": "pnpm --filter @phalanxduel/engine test",
    "test:server": "pnpm --filter @phalanxduel/server test",
    "test:shared": "pnpm --filter @phalanxduel/shared test",
    "coverage:report": "tsx scripts/ci/verify-coverage.ts",
    "schema:gen": "pnpm --filter @phalanxduel/shared schema:gen",
    "schema:check": "bash scripts/ci/verify-schema.sh",
    "rules:check": "tsx scripts/ci/verify-doc-fsm-consistency.ts",
    "dev:server": "pnpm --filter @phalanxduel/server dev",
    "dev:client": "pnpm --filter @phalanxduel/client dev",
    "setup:qa": "bin/qa/bootstrap.zsh",
    "diagnostics": "bash bin/maint/report-diagnostics.sh",
    "version:sync": "bash bin/maint/sync-version.sh",
    "qa:playthrough": "tsx bin/qa/simulate-headless.ts",
    "qa:playthrough:batch": "tsx bin/qa/simulate-headless.ts --batch 10",
    "qa:playthrough:ui": "tsx bin/qa/simulate-ui.ts",
    "otel:console": "otelcol-contrib --config otel-collector-console.yaml",
    "sentry:release": "bash scripts/release/track-sentry.sh",
    "docs:build": "typedoc",
    "docs:dash": "bash scripts/build/generate-docset.sh",
    "deploy:prod": "bash scripts/release/deploy-fly.sh",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.2",
      "ajv@^8.0.0": "^8.18.0",
      "@eslint/plugin-kit": ">=0.3.4"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.21.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-mermaid": "^1.12.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "4.0.18"
  }
}
