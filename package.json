{
  "name": "@phalanxduel/root",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" --config .markdownlint-cli2.jsonc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "deps:prune-store": "pnpm store prune",
    "check:quick": "pnpm build && pnpm lint && pnpm typecheck && pnpm schema:check && pnpm rules:check && pnpm flags:check && pnpm docs:check && pnpm lint:md",
    "check:ci": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm schema:check && pnpm rules:check && pnpm flags:check && pnpm docs:check && pnpm lint:md && pnpm format:check",
    "test:coverage": "pnpm --filter @phalanxduel/shared test:coverage && pnpm --filter @phalanxduel/engine test:coverage && pnpm --filter @phalanxduel/server test:coverage && pnpm coverage:report",
    "test:engine": "pnpm --filter @phalanxduel/engine test",
    "test:server": "pnpm --filter @phalanxduel/server test",
    "test:shared": "pnpm --filter @phalanxduel/shared test",
    "coverage:report": "tsx scripts/ci/verify-coverage.ts",
    "schema:gen": "pnpm --filter @phalanxduel/shared schema:gen",
    "schema:check": "bash scripts/ci/verify-schema.sh",
    "rules:check": "tsx scripts/ci/verify-doc-fsm-consistency.ts && tsx scripts/ci/verify-event-log.ts",
    "flags:check": "tsx scripts/ci/verify-feature-flag-env.ts",
    "qa:anomalies": "tsx scripts/ci/verify-playthrough-anomalies.ts",
    "dev:server": "pnpm --filter @phalanxduel/server dev",
    "dev:client": "pnpm --filter @phalanxduel/client dev",
    "dev:admin": "pnpm --filter @phalanxduel/admin dev",
    "admin:reset-password": "tsx admin/scripts/reset-password.ts",
    "setup:qa": "bin/qa/bootstrap.zsh",
    "diagnostics": "bash bin/maint/report-diagnostics.sh",
    "version:sync": "bash bin/maint/sync-version.sh",
    "qa:playthrough": "tsx bin/qa/simulate-headless.ts",
    "qa:playthrough:batch": "tsx bin/qa/simulate-headless.ts --batch 10",
    "qa:playthrough:matrix": "tsx bin/qa/simulate-headless.ts --damage-modes classic,cumulative --starting-lps 1,20,100 --batch 2 --max-turns 180",
    "qa:playthrough:verify": "pnpm qa:playthrough:matrix && pnpm qa:anomalies -- --latest 12",
    "qa:playthrough:ui": "tsx bin/qa/simulate-ui.ts",
    "otel:console": "bash bin/maint/run-otel-console.sh",
    "otel:signoz": "bash bin/maint/run-otel-signoz.sh",
    "sentry:release": "bash scripts/release/track-sentry.sh",
    "docs:dependency-graph": "bash scripts/docs/render-dependency-graph.sh",
    "docs:knip": "bash scripts/docs/render-knip-report.sh",
    "docs:artifacts": "pnpm docs:dependency-graph && pnpm docs:knip",
    "docs:build": "pnpm docs:artifacts && typedoc",
    "docs:check": "bash scripts/ci/verify-doc-artifacts.sh",
    "secrets:push:staging": "tsx scripts/maint/sync-secrets.ts push staging",
    "secrets:push:production": "tsx scripts/maint/sync-secrets.ts push production",
    "secrets:audit:staging": "tsx scripts/maint/sync-secrets.ts audit staging",
    "secrets:audit:production": "tsx scripts/maint/sync-secrets.ts audit production",
    "secrets:prune:staging": "tsx scripts/maint/sync-secrets.ts prune staging",
    "secrets:prune:production": "tsx scripts/maint/sync-secrets.ts prune production",
    "secrets:remove:staging": "tsx scripts/maint/sync-secrets.ts remove staging",
    "secrets:remove:production": "tsx scripts/maint/sync-secrets.ts remove production",
    "docs:dash": "bash scripts/build/generate-docset.sh",
    "deploy:staging": "APP_ENV=staging bash scripts/release/deploy-fly.sh",
    "deploy:prod": "APP_ENV=production bash scripts/release/deploy-fly.sh",
    "deploy:prod:watch": "APP_ENV=production bash scripts/release/deploy-fly-with-logs.sh",
    "health:check": "tsx scripts/health-check.ts",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "ajv@^8.0.0": "^8.18.0",
      "@eslint/plugin-kit": ">=0.3.4",
      "esbuild@<=0.24.2": "0.25.12"
    },
    "onlyBuiltDependencies": [
      "@sentry-internal/node-cpu-profiler",
      "@sentry/cli",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@viz-js/viz": "^3.25.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dependency-cruiser": "^17.3.9",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "execa": "^5.1.1",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.4",
    "markdownlint-cli2": "^0.21.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-mermaid": "^1.12.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "4.1.0",
    "zod": "^4.3.6"
  }
}
