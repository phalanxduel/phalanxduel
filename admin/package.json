{
  "name": "@phalanxduel/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"sh -c 'set -a; . ../.env.local; set +a; exec tsx watch src/server/index.ts'\" \"vite\"",
    "build": "vite build && tsc --noEmit",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@phalanxduel/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "postgres": "^3.4.8",
    "preact": "^10.26.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
