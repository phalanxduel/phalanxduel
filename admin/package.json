{
  "name": "@phalanxduel/admin",
  "version": "1.0.0-rev.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "dev": "concurrently \"bash ../bin/maint/with-dev-postgres.sh tsx watch src/server/index.ts\" \"vite\"",
