                                  "type": "string",
                                },
                                "matchParams": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "classic": {
                                      "additionalProperties": false,
                                      "properties": {
                                        "battlefield": {
                                          "additionalProperties": false,
                                          "properties": {
                                            "columns": {
                                              "default": 4,
                                              "description": "Number of columns per player board. Default: 4. Max: 12 (§3.3).",
                                              "maximum": 12,
                                              "minimum": 1,
                                              "type": "integer",
                                            },
                                            "rows": {
                                              "default": 2,
                                              "description": "Number of ranks (rows) per column. Default: 2. Max: 12 (§3.3).",
                                              "maximum": 12,
                                              "minimum": 1,
                                              "type": "integer",
                                            },
                                          },
                                          "required": [
                                            "rows",
                                            "columns",
                                          ],
                                          "type": "object",
                                        },
                                        "enabled": {
                                          "description": "Whether Classic schema binding is active (§3.1).",
                                          "type": "boolean",
                                        },
                                        "hand": {
                                          "additionalProperties": false,
                                          "properties": {
                                            "maxHandSize": {
                                              "default": 4,
                                              "description": "Maximum hand size. Must be ≤ columns (§3.3). Default: 4.",
                                              "maximum": 12,
                                              "minimum": 0,
                                              "type": "integer",
                                            },
                                          },
                                          "required": [
                                            "maxHandSize",
                                          ],
                                          "type": "object",
                                        },
                                        "initiative": {
                                          "additionalProperties": false,
                                          "properties": {
                                            "attackFirst": {
                                              "default": "P1",
                                              "description": "Which player attacks first in AttackPhase.",
                                              "enum": [
                                                "P1",
                                                "P2",
                                              ],
                                              "type": "string",
                                            },
                                            "deployFirst": {
                                              "default": "P2",
                                              "description": "Which player deploys first in DeploymentPhase.",
                                              "enum": [
                                                "P1",
                                                "P2",
                                              ],
                                              "type": "string",
                                            },
                                          },
                                          "required": [
                                            "deployFirst",
                                            "attackFirst",
                                          ],
                                          "type": "object",
                                        },
                                        "mode": {
                                          "default": "strict",
                                          "description": "Classic schema binding mode (§3.1). strict: all top-level parameters must exactly match the classic template. hybrid: classic values serve as defaults, top-level may override within Global System Constraints.",
                                          "enum": [
                                            "strict",
                                            "hybrid",
                                          ],
                                          "type": "string",
                                        },
                                        "modes": {
                                          "additionalProperties": false,
                                          "properties": {
                                            "classicAces": {
                                              "default": true,
                                              "description": "Enable Classic Ace rules: Aces only destroyed by other Aces at rank 0 (§10).",
                                              "type": "boolean",
