    "/api/matches/{matchId}/verify": {
      "get": {
        "description": "Replays the match action history and verifies the state hash chain against either in-memory or persisted state.",
        "parameters": [
          {
            "in": "path",
            "name": "matchId",
            "required": true,
            "schema": {
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "actionCount": {
                      "maximum": 9007199254740991,
                      "minimum": -9007199254740991,
                      "type": "integer",
                    },
                    "error": {
                      "type": "string",
                    },
                    "failedAtIndex": {
                      "maximum": 9007199254740991,
                      "minimum": -9007199254740991,
                      "type": "integer",
                    },
                    "finalStateHash": {
                      "type": "string",
                    },
                    "hashChain": {
                      "additionalProperties": false,
                      "properties": {
                        "actionCount": {
                          "maximum": 9007199254740991,
                          "minimum": -9007199254740991,
                          "type": "integer",
                        },
                        "error": {
                          "type": "string",
                        },
                        "finalStateHash": {
                          "anyOf": [
                            {
                              "type": "string",
                            },
                            {
                              "type": "null",
                            },
                          ],
                        },
                        "valid": {
                          "type": "boolean",
                        },
                      },
                      "required": [
                        "valid",
                        "actionCount",
                        "finalStateHash",
                      ],
                      "type": "object",
                    },
                    "source": {
                      "enum": [
                        "memory",
                        "database",
                      ],
                      "type": "string",
                    },
                    "storedFinalHash": {
                      "type": "string",
                    },
                    "valid": {
                      "type": "boolean",
                    },
                  },
                  "required": [
                    "valid",
                    "source",
                    "actionCount",
                    "finalStateHash",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Verify match integrity",
        "tags": [
          "matches",
        ],
      },
    },
    "/api/rules/phases": {
      "get": {
        "description": "Returns the state machine transition table for game phases.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "The canonical state machine transitions",
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "action": {
                        "type": "string",
                      },
                      "description": {
                        "type": "string",
                      },
                      "from": {
                        "anyOf": [
                          {
                            "description": "Deterministic turn lifecycle phase (RULES.md §4). Each turn executes all 8 phases in order: StartTurn → DeploymentPhase → AttackPhase → AttackResolution → CleanupPhase → ReinforcementPhase → DrawPhase → EndTurn. Player actions are only valid in specific phases.",
                            "enum": [
                              "StartTurn",
                              "DeploymentPhase",
                              "AttackPhase",
                              "AttackResolution",
                              "CleanupPhase",
                              "ReinforcementPhase",
                              "DrawPhase",
                              "EndTurn",
                            ],
                            "type": "string",
                          },
                          {
                            "enum": [
                              "gameOver",
                            ],
                            "type": "string",
                          },
                        ],
                        "description": "Current game phase. One of the 8 turn lifecycle phases or gameOver. The gameOver phase is terminal and set when a victory condition is met (LP depletion, card depletion, forfeit, or pass limit).",
                      },
                      "to": {
                        "anyOf": [
                          {
                            "description": "Deterministic turn lifecycle phase (RULES.md §4). Each turn executes all 8 phases in order: StartTurn → DeploymentPhase → AttackPhase → AttackResolution → CleanupPhase → ReinforcementPhase → DrawPhase → EndTurn. Player actions are only valid in specific phases.",
                            "enum": [
                              "StartTurn",
                              "DeploymentPhase",
                              "AttackPhase",
                              "AttackResolution",
                              "CleanupPhase",
                              "ReinforcementPhase",
                              "DrawPhase",
                              "EndTurn",
                            ],
                            "type": "string",
                          },
                          {
                            "enum": [
                              "gameOver",
                            ],
                            "type": "string",
                          },
                        ],
                        "description": "Current game phase. One of the 8 turn lifecycle phases or gameOver. The gameOver phase is terminal and set when a victory condition is met (LP depletion, card depletion, forfeit, or pass limit).",
                      },
                      "trigger": {
                        "description": "State machine trigger that causes a phase transition. Player triggers: deploy, attack, pass, reinforce, forfeit. System triggers: deploy:complete, attack:reinforcement, attack:victory, reinforce:complete, system:advance, system:victory, system:init.",
                        "enum": [
                          "deploy",
                          "deploy:complete",
                          "attack",
                          "attack:reinforcement",
                          "attack:victory",
                          "pass",
                          "reinforce",
                          "reinforce:complete",
                          "forfeit",
                          "system:advance",
                          "system:victory",
                          "system:init",
                        ],
                        "type": "string",
                      },
                    },
                    "required": [
                      "from",
                      "to",
                      "trigger",
                      "description",
                    ],
                    "type": "object",
                  },
                  "type": "array",
                },
              },
            },
            "description": "The canonical state machine transitions",
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Rule Discovery: Phases",
        "tags": [
          "discovery",
        ],
      },
    },
