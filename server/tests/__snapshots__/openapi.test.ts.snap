                              "type": "string",
                            },
                            "modePassRules": {
                              "additionalProperties": false,
                              "properties": {
                                "maxConsecutivePasses": {
                                  "description": "Maximum consecutive passes before automatic forfeit (§16).",
                                  "maximum": 100,
                                  "minimum": 1,
                                  "type": "integer",
