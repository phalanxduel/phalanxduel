                              "type": "string",
                            },
                            {
                              "enum": [
                                "gameOver",
                              ],
                              "type": "string",
                            },
                          ],
                          "description": "Current game phase. One of the 8 turn lifecycle phases or gameOver. The gameOver phase is terminal and set when a victory condition is met (LP depletion, card depletion, forfeit, or pass limit).",
                        },
                        "players": {
                          "description": "Exactly 2 player states. Index 0 = P1 (inviting), Index 1 = P2 (invited).",
                          "items": {
                            "additionalProperties": false,
                            "properties": {
                              "battlefield": {
                                "description": "Battlefield grid slots. Array of rows × columns elements. null = empty slot. Visible to all (§21.2).",
                                "items": {
                                  "anyOf": [
                                    {
                                      "additionalProperties": false,
                                      "properties": {
                                        "card": {
                                          "additionalProperties": false,
                                          "properties": {
                                            "face": {
                                              "description": "Card face symbol. One of: A (Ace), 2-9, T (Ten), J (Jack), Q (Queen), K (King). Maps to value via RANK_VALUES lookup.",
                                              "pattern": "^[A2-9TJQK]$",
                                              "type": "string",
                                            },
                                            "id": {
                                              "description": "Opaque deterministic card ID. Format: [Timestamp]::[MatchID]::[PlayerID]::[TurnNumber]::[DrawIndex]. Generated at draw-time. No card info is encoded into the suffix.",
                                              "minLength": 1,
                                              "type": "string",
                                            },
                                            "suit": {
                                              "description": "Card suit. Determines boundary effects during attack resolution: ♦ Diamond (double defense at Card→Card boundary), ♥ Heart (death shield at Card→Player boundary), ♣ Club (double overflow after first destruction), ♠ Spade (double LP damage at Card→Player boundary). See RULES.md §9.",
                                              "enum": [
                                                "spades",
                                                "hearts",
                                                "diamonds",
                                                "clubs",
                                              ],
                                              "type": "string",
                                            },
                                            "type": {
                                              "description": "Card type classification. Governs destruction eligibility under Classic Aces (§10) and Classic Face Cards (§11) rules. Aces are only destroyed by other aces at rank 0. Face cards follow a hierarchy: J→J, Q→J/Q, K→J/Q/K.",
                                              "enum": [
                                                "number",
                                                "ace",
                                                "jack",
                                                "queen",
                                                "king",
                                                "joker",
                                              ],
                                              "type": "string",
                                            },
                                            "value": {
                                              "description": "Numeric combat value. A=1, 2-9=face value, T=10, J/Q/K=11. Used as base damage in attack resolution.",
                                              "maximum": 11,
                                              "minimum": 0,
                                              "type": "integer",
                                            },
                                          },
                                          "required": [
                                            "id",
                                            "suit",
                                            "face",
                                            "value",
                                            "type",
                                          ],
                                          "type": "object",
                                        },
                                        "currentHp": {
                                          "description": "Current hit points. Equals card value at deployment. Reduced by incoming damage during attack resolution. Card is destroyed when reduced to 0 (subject to destruction eligibility rules §10-11).",
                                          "maximum": 11,
                                          "minimum": 0,
                                          "type": "integer",
                                        },
                                        "faceDown": {
                                          "description": "Whether the card is face-down. Canonical v1.0 gameplay keeps battlefield cards face-up (\`false\`). This field remains for forward-compatibility and non-v1 visibility experiments; see §21.2.",
                                          "type": "boolean",
                                        },
                                        "position": {
                                          "additionalProperties": false,
                                          "properties": {
                                            "col": {
                                              "description": "Column index on the battlefield. Max 11 per Global System Constraints §3.3.",
                                              "maximum": 11,
                                              "minimum": 0,
                                              "type": "integer",
                                            },
                                            "row": {
                                              "description": "Rank index within a column (0 = front, facing opponent). Max 11 per Global System Constraints §3.3.",
                                              "maximum": 11,
                                              "minimum": 0,
                                              "type": "integer",
                                            },
                                          },
                                          "required": [
                                            "row",
                                            "col",
                                          ],
                                          "type": "object",
                                        },
                                      },
                                      "required": [
                                        "card",
                                        "position",
                                        "currentHp",
                                        "faceDown",
                                      ],
                                      "type": "object",
                                    },
                                    {
                                      "type": "null",
                                    },
                                  ],
                                },
                                "type": "array",
                              },
                              "deckSeed": {
                                "description": "Deterministic RNG seed for deck shuffling. Ensures replay reproducibility.",
                                "maximum": 9007199254740991,
                                "minimum": -9007199254740991,
                                "type": "integer",
                              },
                              "discardPile": {
                                "description": "Destroyed cards. Owner sees full pile; others see only top card and count (§21.3).",
                                "items": {
                                  "additionalProperties": false,
