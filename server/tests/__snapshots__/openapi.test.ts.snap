                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "error": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "error": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Replay and validate a match from its action history",
        "tags": [
          "matches",
        ],
      },
    },
    "/ready": {
      "get": {
        "description": "Returns 200 if the app is ready to handle traffic, including database connectivity.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "database": {
                      "enum": [
                        "ok",
                        "unhealthy",
                      ],
                      "type": "string",
                    },
                    "ready": {
                      "type": "boolean",
                    },
                    "timestamp": {
                      "format": "date-time",
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "database": {
                      "enum": [
                        "ok",
                        "unhealthy",
                      ],
                      "type": "string",
                    },
                    "error": {
                      "type": "string",
                    },
                    "ready": {
                      "type": "boolean",
                    },
                    "timestamp": {
                      "format": "date-time",
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Server readiness check",
        "tags": [
