                            "maximum": 100,
                            "minimum": 1,
                            "type": "integer",
                          },
                          "maxTotalPassesPerPlayer": {
                            "default": 5,
                            "description": "Maximum total passes per player before automatic forfeit (§16). Default: 5.",
                            "maximum": 100,
                            "minimum": 1,
                            "type": "integer",
