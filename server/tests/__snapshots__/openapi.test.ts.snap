    "/api/matches/{id}/action": {
      "post": {
        "description": "Applies a gameplay action for an authenticated participant and returns the redacted TurnViewModel for that player.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "description": "A gameplay action using the canonical shared action schema.",
                "properties": {
                  "playerIndex": {
                    "type": "integer",
                  },
                  "timestamp": {
                    "format": "date-time",
                    "type": "string",
                  },
                  "type": {
                    "type": "string",
                  },
                },
                "required": [
                  "type",
                ],
                "type": "object",
              },
            },
          },
          "description": "A gameplay action using the canonical shared action schema.",
          "required": true,
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "description": "The redacted turn result for the acting player",
                  "properties": {
                    "action": {
                      "description": "Authoritative action payload for Phalanx: Duel.",
                      "oneOf": [
                        {
                          "additionalProperties": false,
                          "description": "Deploy a card from hand. Valid during DeploymentPhase. Each player must alternate deploying cards until the battlefield is full according to match parameters.",
                          "properties": {
                            "cardId": {
                              "description": "ID of the card to deploy from hand.",
                              "type": "string",
                            },
                            "column": {
                              "description": "Battlefield column index (0-11).",
                              "maximum": 11,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "playerIndex": {
                              "description": "Index of the player (0 or 1).",
                              "maximum": 1,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "timestamp": {
                              "format": "date-time",
                              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                              "type": "string",
                            },
                            "type": {
                              "enum": [
                                "deploy",
                              ],
                              "type": "string",
                            },
                          },
                          "required": [
                            "type",
                            "playerIndex",
                            "column",
                            "cardId",
                            "timestamp",
                          ],
                          "type": "object",
                        },
                        {
                          "additionalProperties": false,
                          "description": "Declare an attack. Valid during AttackPhase. Requires a card at rank 0 of the attacking column.",
                          "properties": {
                            "attackingColumn": {
                              "description": "Column index containing the attacking card. Must have a non-null card at rank 0.",
                              "maximum": 11,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "defendingColumn": {
                              "description": "Target column index on the opponent board.",
                              "maximum": 11,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "playerIndex": {
                              "description": "Index of the player (0 or 1).",
                              "maximum": 1,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "timestamp": {
                              "format": "date-time",
                              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                              "type": "string",
                            },
                            "type": {
                              "enum": [
                                "attack",
                              ],
                              "type": "string",
                            },
                          },
                          "required": [
                            "type",
                            "playerIndex",
                            "attackingColumn",
                            "defendingColumn",
                            "timestamp",
                          ],
                          "type": "object",
                        },
                        {
                          "additionalProperties": false,
                          "description": "Pass the current turn. Valid during AttackPhase. Excessive consecutive or total passes will result in a forfeit.",
                          "properties": {
                            "playerIndex": {
                              "description": "Index of the player (0 or 1).",
                              "maximum": 1,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "timestamp": {
                              "format": "date-time",
                              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                              "type": "string",
                            },
                            "type": {
                              "enum": [
                                "pass",
                              ],
                              "type": "string",
                            },
                          },
                          "required": [
                            "type",
                            "playerIndex",
                            "timestamp",
                          ],
                          "type": "object",
                        },
                        {
                          "additionalProperties": false,
                          "description": "Reinforce a column after cleanup. Valid during ReinforcementPhase. Cards are deployed to the back-most empty rank of the column.",
                          "properties": {
                            "cardId": {
                              "description": "ID of the card to deploy from hand.",
                              "type": "string",
                            },
                            "playerIndex": {
                              "description": "Index of the player (0 or 1).",
                              "maximum": 1,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "timestamp": {
                              "format": "date-time",
