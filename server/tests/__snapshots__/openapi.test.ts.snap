  "info": {
    "description": "Authoritative game server for Phalanx Duel. External event validation schemas are available at [api/EVENT_SCHEMAS.md](https://github.com/phalanxduel/phalanxduel/blob/main/docs/api/EVENT_SCHEMAS.md).",
    "title": "Phalanx Duel Game Server",
    "version": "<redacted-version>",
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/auth/gamertag": {
      "post": {
        "description": "Updates the authenticated user gamertag and assigns a new suffix. Limited to once every 7 days.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "gamertag": {
                    "maxLength": 20,
                    "minLength": 3,
                    "type": "string",
                  },
                },
                "required": [
                  "gamertag",
                ],
                "type": "object",
              },
            },
          },
          "required": true,
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "token": {
                      "type": "string",
                    },
                    "user": {
                      "additionalProperties": false,
                      "properties": {
                        "elo": {
                          "maximum": 9007199254740991,
                          "minimum": -9007199254740991,
                          "type": "integer",
                        },
                        "email": {
                          "format": "email",
                          "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
                          "type": "string",
                        },
                        "gamertag": {
