              ],
            },
            "type": "array",
          },
          "viewerIndex": {
            "anyOf": [
              {
                "maximum": 1,
                "minimum": 0,
                "type": "integer",
              },
              {
                "type": "null",
              },
            ],
          },
        },
        "required": [
          "matchId",
          "viewerIndex",
          "preState",
          "postState",
          "action",
          "validActions",
        ],
        "type": "object",
      },
      "VictoryType": {
        "description": "Victory condition type. lpDepletion: opponent LP reaches 0. cardDepletion: opponent has no cards on battlefield or in hand. forfeit: player explicitly forfeits. passLimit: player exceeds maxConsecutivePasses or maxTotalPassesPerPlayer (§16).",
        "enum": [
          "lpDepletion",
          "cardDepletion",
          "forfeit",
          "passLimit",
        ],
        "type": "string",
      },
    },
    "securitySchemes": {
      "basicAuth": {
        "scheme": "basic",
        "type": "http",
      },
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http",
      },
      "cookieAuth": {
        "in": "cookie",
        "name": "phalanx_refresh",
        "type": "apiKey",
      },
    },
  },
  "info": {
    "description": "Authoritative game server for Phalanx Duel.

## Authoritative References

- **[RULES.md](https://github.com/phalanxduel/game/blob/main/docs/RULES.md)** — Canonical deterministic rules specification (v1.0). All game logic, state machine transitions, suit boundary effects, and victory conditions are defined here.
- **[EVENT_SCHEMAS.md](https://github.com/phalanxduel/game/blob/main/docs/api/EVENT_SCHEMAS.md)** — External event validation schemas.
- **[AsyncAPI Spec](/docs/asyncapi.yaml)** — WebSocket protocol specification for real-time gameplay.

## Discovery Endpoints

- \`GET /api/rules/phases\` — State machine transition table. Returns all valid phase transitions and their triggers.
- \`GET /api/cards/manifest\` — Card manifest. Returns all possible cards in a standard deck with deterministic stats.
- \`GET /api/defaults\` — Default match parameters and system constraints.

## State Machine Constraints

A schema-valid action can be semantically invalid if sent in the wrong phase. The \`deploy\` action is only valid during \`DeploymentPhase\`. The \`attack\` and \`pass\` actions are only valid during \`AttackPhase\`. The \`reinforce\` action is only valid during \`ReinforcementPhase\`. The \`forfeit\` action is valid in any phase. See the \`/api/rules/phases\` endpoint for the full transition table.",
    "title": "Phalanx Duel Game Server",
    "version": "<redacted-version>",
  },
  "openapi": "3.0.3",
