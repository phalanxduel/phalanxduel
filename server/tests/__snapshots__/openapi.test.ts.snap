                                              "default": true,
                                              "description": "Enable Classic Face Card rules: J→J, Q→J/Q, K→J/Q/K destruction hierarchy (§11).",
                                              "type": "boolean",
                                            },
                                            "damagePersistence": {
                                              "default": "classic",
                                              "description": "Damage mode. classic: no HP persists between turns. cumulative: damage persists (§12).",
                                              "enum": [
                                                "classic",
                                                "cumulative",
                                              ],
                                              "type": "string",
                                            },
                                            "quickStart": {
                                              "default": false,
                                              "description": "Reserved compatibility flag. Must be false for v1.0-compliant matches (§3.4).",
                                              "type": "boolean",
