                              "enum": [
                                "gameOver",
                              ],
                              "type": "string",
                            },
                          ],
                          "description": "Current game phase. One of the 8 turn lifecycle phases or gameOver. The gameOver phase is terminal and set when a victory condition is met (LP depletion, card depletion, forfeit, or pass limit).",
                        },
                        "players": {
                          "description": "Exactly 2 player states. Index 0 = P1 (inviting), Index 1 = P2 (invited).",
                          "items": {
                            "additionalProperties": false,
                            "properties": {
                              "battlefield": {
                                "description": "Battlefield grid slots. Array of rows × columns elements. null = empty slot. Visible to all (§21.2).",
