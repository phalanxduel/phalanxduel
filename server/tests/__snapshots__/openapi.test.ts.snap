    "/api/matches/{matchId}/verify": {
      "get": {
        "description": "Replays the match action history and verifies the state hash chain against either in-memory or persisted state.",
        "parameters": [
          {
            "in": "path",
            "name": "matchId",
            "required": true,
            "schema": {
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "actionCount": {
                      "maximum": 9007199254740991,
                      "minimum": -9007199254740991,
                      "type": "integer",
                    },
                    "error": {
                      "type": "string",
                    },
                    "failedAtIndex": {
                      "maximum": 9007199254740991,
                      "minimum": -9007199254740991,
                      "type": "integer",
                    },
                    "finalStateHash": {
                      "type": "string",
                    },
                    "hashChain": {
                      "additionalProperties": false,
                      "properties": {
                        "actionCount": {
                          "maximum": 9007199254740991,
                          "minimum": -9007199254740991,
                          "type": "integer",
                        },
                        "error": {
                          "type": "string",
                        },
                        "finalStateHash": {
                          "anyOf": [
                            {
                              "type": "string",
                            },
                            {
                              "type": "null",
                            },
                          ],
                        },
                        "valid": {
                          "type": "boolean",
                        },
                      },
                      "required": [
                        "valid",
                        "actionCount",
                        "finalStateHash",
                      ],
                      "type": "object",
                    },
                    "source": {
                      "enum": [
                        "memory",
                        "database",
                      ],
                      "type": "string",
                    },
                    "storedFinalHash": {
                      "type": "string",
                    },
                    "valid": {
                      "type": "boolean",
                    },
                  },
                  "required": [
                    "valid",
                    "source",
                    "actionCount",
                    "finalStateHash",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Verify match integrity",
        "tags": [
          "matches",
        ],
      },
    },
