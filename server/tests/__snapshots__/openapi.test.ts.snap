                          "requirements": {
                            "additionalProperties": false,
                            "properties": {
                              "maxPublicRating": {
                                "anyOf": [
                                  {
                                    "maximum": 9007199254740991,
                                    "minimum": -9007199254740991,
                                    "type": "integer",
                                  },
                                  {
                                    "type": "null",
                                  },
                                ],
                              },
                              "minGamesPlayed": {
                                "anyOf": [
                                  {
                                    "maximum": 9007199254740991,
                                    "minimum": -9007199254740991,
                                    "type": "integer",
                                  },
                                  {
                                    "type": "null",
                                  },
                                ],
                              },
                              "minPublicRating": {
                                "anyOf": [
                                  {
                                    "maximum": 9007199254740991,
                                    "minimum": -9007199254740991,
                                    "type": "integer",
                                  },
                                  {
                                    "type": "null",
                                  },
                                ],
                              },
                              "requiresEstablishedRating": {
                                "type": "boolean",
                              },
                            },
                            "required": [
                              "minPublicRating",
                              "maxPublicRating",
                              "minGamesPlayed",
                              "requiresEstablishedRating",
                            ],
                            "type": "object",
                          },
                        },
                        "required": [
