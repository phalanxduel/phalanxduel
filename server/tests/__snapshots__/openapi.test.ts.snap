                                            "enum": [
                                              "strict",
                                              "hybrid",
                                            ],
                                            "type": "string",
                                          },
                                          "modes": {
                                            "additionalProperties": false,
                                            "properties": {
                                              "classicAces": {
                                                "default": true,
                                                "description": "Enable Classic Ace rules: Aces only destroyed by other Aces at rank 0 (§10).",
                                                "type": "boolean",
