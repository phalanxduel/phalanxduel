              "gameOptions": {
                "additionalProperties": false,
                "description": "Runtime compatibility inputs applied at match creation. These fields are transport-facing and do not supersede the canonical match params contract.",
                "properties": {
                  "classicDeployment": {
                    "default": true,
                    "description": "Compatibility-only runtime override for deployment bootstrap. Canonical v1.0 rule authority belongs to \`modeClassicDeployment\` in the match params.",
                    "type": "boolean",
                  },
                  "damageMode": {
                    "default": "classic",
                    "description": "Compatibility-only runtime override. Canonical v1.0 rule authority belongs to match params \`modeDamagePersistence\`, not \`gameOptions.damageMode\`.",
                    "enum": [
                      "classic",
                      "cumulative",
                    ],
                    "type": "string",
                  },
                  "quickStart": {
                    "description": "Compatibility-only bootstrap shortcut. If true, runtime may skip deployment and pre-fill the battlefield, but canonical v1.0-compliant matches keep this disabled.",
                    "type": "boolean",
                  },
                  "startingLifepoints": {
                    "default": 20,
                    "description": "Compatibility-only runtime override for bootstrap surfaces. Canonical v1.0 gameplay is defined by the match params contract, not \`gameOptions.startingLifepoints\`.",
                    "maximum": 500,
                    "minimum": 1,
                    "type": "integer",
                  },
                },
                "required": [
                  "damageMode",
                  "startingLifepoints",
                  "classicDeployment",
                ],
                "type": "object",
              },
              "matchId": {
                "description": "Unique match identifier (UUID v4).",
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                "type": "string",
              },
              "outcome": {
                "anyOf": [
                  {
                    "additionalProperties": false,
                    "properties": {
                      "turnNumber": {
                        "description": "Turn number when victory was achieved.",
                        "maximum": 9007199254740991,
                        "minimum": 0,
                        "type": "integer",
                      },
                      "victoryType": {
                        "description": "Victory condition type. lpDepletion: opponent LP reaches 0. cardDepletion: opponent has no cards on battlefield or in hand. forfeit: player explicitly forfeits. passLimit: player exceeds maxConsecutivePasses or maxTotalPassesPerPlayer (§16).",
                        "enum": [
                          "lpDepletion",
                          "cardDepletion",
                          "forfeit",
                          "passLimit",
                        ],
                        "type": "string",
                      },
                      "winnerIndex": {
                        "description": "Index of the winning player (0 or 1).",
                        "maximum": 1,
                        "minimum": 0,
                        "type": "integer",
                      },
                    },
                    "required": [
                      "winnerIndex",
                      "victoryType",
                      "turnNumber",
                    ],
                    "type": "object",
                  },
                  {
                    "type": "null",
                  },
                ],
                "description": "Match outcome. Present only when phase is gameOver.",
              },
              "params": {
                "additionalProperties": false,
                "properties": {
                  "classic": {
                    "additionalProperties": false,
                    "properties": {
                      "battlefield": {
                        "additionalProperties": false,
                        "properties": {
                          "columns": {
                            "default": 4,
                            "description": "Number of columns per player board. Default: 4. Max: 12 (§3.3).",
