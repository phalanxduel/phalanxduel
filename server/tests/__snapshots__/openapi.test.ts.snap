    "/api/ladder/{category}": {
      "get": {
        "description": "Returns the top rankings for a specific category (pvp, sp-random, sp-heuristic).",
        "parameters": [
          {
            "in": "path",
            "name": "category",
            "required": true,
            "schema": {
              "enum": [
                "pvp",
                "sp-random",
                "sp-heuristic",
              ],
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "category": {
                      "type": "string",
                    },
                    "computedAt": {
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                      "type": "string",
                    },
                    "rankings": {
                      "items": {
                        "additionalProperties": false,
                        "properties": {
                          "elo": {
                            "maximum": 9007199254740991,
                            "minimum": -9007199254740991,
                            "type": "integer",
                          },
                          "gamertag": {
                            "type": "string",
                          },
                          "matches": {
                            "maximum": 9007199254740991,
                            "minimum": -9007199254740991,
                            "type": "integer",
                          },
                          "rank": {
                            "maximum": 9007199254740991,
                            "minimum": -9007199254740991,
                            "type": "integer",
                          },
                          "userId": {
                            "format": "uuid",
                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                            "type": "string",
                          },
                          "wins": {
                            "maximum": 9007199254740991,
                            "minimum": -9007199254740991,
                            "type": "integer",
                          },
                        },
                        "required": [
                          "rank",
                          "userId",
                          "gamertag",
                          "elo",
                          "matches",
                          "wins",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "windowDays": {
                      "maximum": 9007199254740991,
                      "minimum": -9007199254740991,
                      "type": "integer",
                    },
                  },
                  "required": [
                    "category",
                    "windowDays",
                    "computedAt",
                    "rankings",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Get leaderboard by category",
        "tags": [
          "ladder",
        ],
      },
