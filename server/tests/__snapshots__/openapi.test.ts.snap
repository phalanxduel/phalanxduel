                          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                          "type": "string",
                        },
                        "gameOptions": {
                          "additionalProperties": false,
                          "properties": {
                            "classicDeployment": {
                              "default": true,
                              "description": "Compatibility-only runtime override for deployment bootstrap. Canonical v1.0 rule authority belongs to \`modeClassicDeployment\` in the match params.",
                              "type": "boolean",
                            },
                            "damageMode": {
                              "default": "classic",
                              "description": "Compatibility-only runtime override. Canonical v1.0 rule authority belongs to match params \`modeDamagePersistence\`, not \`gameOptions.damageMode\`.",
                              "enum": [
                                "classic",
                                "cumulative",
                              ],
                              "type": "string",
                            },
                            "quickStart": {
                              "description": "Compatibility-only bootstrap shortcut. If true, runtime may skip deployment and pre-fill the battlefield, but canonical v1.0-compliant matches keep this disabled.",
                              "type": "boolean",
                            },
                            "startingLifepoints": {
                              "default": 20,
                              "description": "Compatibility-only runtime override for bootstrap surfaces. Canonical v1.0 gameplay is defined by the match params contract, not \`gameOptions.startingLifepoints\`.",
                              "maximum": 500,
                              "minimum": 1,
                              "type": "integer",
                            },
                          },
                          "required": [
                            "damageMode",
                            "startingLifepoints",
                            "classicDeployment",
                          ],
                          "type": "object",
                        },
                        "matchId": {
                          "format": "uuid",
                          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                          "type": "string",
                        },
                        "matchParams": {
                          "additionalProperties": false,
                          "properties": {
                            "classic": {
                              "additionalProperties": false,
                              "properties": {
                                "battlefield": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "columns": {
                                      "default": 4,
                                      "description": "Number of columns per player board. Default: 4. Max: 12 (§3.3).",
                                      "maximum": 12,
                                      "minimum": 1,
                                      "type": "integer",
                                    },
                                    "rows": {
                                      "default": 2,
                                      "description": "Number of ranks (rows) per column. Default: 2. Max: 12 (§3.3).",
                                      "maximum": 12,
                                      "minimum": 1,
                                      "type": "integer",
                                    },
                                  },
                                  "required": [
                                    "rows",
                                    "columns",
                                  ],
                                  "type": "object",
                                },
                                "enabled": {
                                  "description": "Whether Classic schema binding is active (§3.1).",
                                  "type": "boolean",
                                },
                                "hand": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "maxHandSize": {
                                      "default": 4,
                                      "description": "Maximum hand size. Must be ≤ columns (§3.3). Default: 4.",
                                      "maximum": 12,
                                      "minimum": 0,
                                      "type": "integer",
                                    },
                                  },
                                  "required": [
                                    "maxHandSize",
                                  ],
                                  "type": "object",
                                },
                                "initiative": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "attackFirst": {
                                      "default": "P1",
                                      "description": "Which player attacks first in AttackPhase.",
                                      "enum": [
                                        "P1",
                                        "P2",
                                      ],
                                      "type": "string",
                                    },
                                    "deployFirst": {
                                      "default": "P2",
                                      "description": "Which player deploys first in DeploymentPhase.",
                                      "enum": [
                                        "P1",
                                        "P2",
                                      ],
                                      "type": "string",
                                    },
                                  },
                                  "required": [
                                    "deployFirst",
                                    "attackFirst",
                                  ],
                                  "type": "object",
                                },
                                "mode": {
                                  "default": "strict",
                                  "description": "Classic schema binding mode (§3.1). strict: all top-level parameters must exactly match the classic template. hybrid: classic values serve as defaults, top-level may override within Global System Constraints.",
                                  "enum": [
                                    "strict",
                                    "hybrid",
                                  ],
                                  "type": "string",
                                },
                                "modes": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "classicAces": {
                                      "default": true,
                                      "description": "Enable Classic Ace rules: Aces only destroyed by other Aces at rank 0 (§10).",
                                      "type": "boolean",
                                    },
                                    "classicFaceCards": {
                                      "default": true,
                                      "description": "Enable Classic Face Card rules: J→J, Q→J/Q, K→J/Q/K destruction hierarchy (§11).",
                                      "type": "boolean",
                                    },
                                    "damagePersistence": {
                                      "default": "classic",
                                      "description": "Damage mode. classic: no HP persists between turns. cumulative: damage persists (§12).",
                                      "enum": [
                                        "classic",
                                        "cumulative",
                                      ],
                                      "type": "string",
                                    },
                                    "quickStart": {
                                      "default": false,
                                      "description": "Reserved compatibility flag. Must be false for v1.0-compliant matches (§3.4).",
                                      "type": "boolean",
                                    },
                                  },
                                  "required": [
                                    "classicAces",
                                    "classicFaceCards",
                                    "damagePersistence",
                                    "quickStart",
                                  ],
                                  "type": "object",
                                },
                                "passRules": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "maxConsecutivePasses": {
                                      "default": 3,
                                      "description": "Maximum consecutive passes before automatic forfeit (§16). Default: 3.",
                                      "maximum": 100,
                                      "minimum": 1,
                                      "type": "integer",
                                    },
                                    "maxTotalPassesPerPlayer": {
                                      "default": 5,
                                      "description": "Maximum total passes per player before automatic forfeit (§16). Default: 5.",
                                      "maximum": 100,
                                      "minimum": 1,
                                      "type": "integer",
                                    },
                                  },
                                  "required": [
                                    "maxConsecutivePasses",
                                    "maxTotalPassesPerPlayer",
                                  ],
                                  "type": "object",
                                },
                                "start": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "initialDraw": {
                                      "default": 12,
                                      "description": "Cards drawn at match start. Formula: rows × columns + columns (§3.3). Default: 12.",
                                      "maximum": 60,
                                      "minimum": 1,
                                      "type": "integer",
                                    },
                                  },
                                  "required": [
                                    "initialDraw",
                                  ],
                                  "type": "object",
                                },
                              },
                              "required": [
                                "enabled",
                                "mode",
                                "battlefield",
                                "hand",
                                "start",
                                "modes",
                                "initiative",
                                "passRules",
                              ],
                              "type": "object",
                            },
                            "columns": {
                              "description": "Number of columns per player board (§3.3). Min: 1, Max: 12. rows × columns ≤ 48.",
                              "maximum": 12,
                              "minimum": 1,
                              "type": "integer",
                            },
                            "initialDraw": {
                              "description": "Cards drawn at match start. Must equal rows × columns + columns (§3.3).",
                              "maximum": 60,
                              "minimum": 1,
                              "type": "integer",
                            },
                            "initiative": {
                              "additionalProperties": false,
                              "properties": {
                                "attackFirst": {
                                  "description": "Which player attacks first in AttackPhase.",
                                  "enum": [
                                    "P1",
                                    "P2",
                                  ],
                                  "type": "string",
                                },
                                "deployFirst": {
                                  "description": "Which player deploys first in DeploymentPhase.",
                                  "enum": [
                                    "P1",
                                    "P2",
                                  ],
                                  "type": "string",
                                },
                              },
                              "required": [
                                "deployFirst",
                                "attackFirst",
                              ],
                              "type": "object",
                            },
                            "maxHandSize": {
                              "description": "Maximum hand size. Must be ≤ columns (§3.3).",
                              "maximum": 12,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "modeClassicAces": {
                              "description": "Enable Classic Ace invulnerability rules (§10).",
                              "type": "boolean",
                            },
                            "modeClassicDeployment": {
                              "description": "Enable Classic Deployment: alternating card placement (§5).",
                              "type": "boolean",
                            },
                            "modeClassicFaceCards": {
                              "description": "Enable Classic Face Card destruction hierarchy (§11).",
                              "type": "boolean",
                            },
                            "modeDamagePersistence": {
                              "description": "Damage persistence mode (§12).",
                              "enum": [
                                "classic",
                                "cumulative",
                              ],
                              "type": "string",
                            },
                            "modePassRules": {
                              "additionalProperties": false,
                              "properties": {
                                "maxConsecutivePasses": {
                                  "description": "Maximum consecutive passes before automatic forfeit (§16).",
                                  "maximum": 100,
                                  "minimum": 1,
                                  "type": "integer",
                                },
                                "maxTotalPassesPerPlayer": {
                                  "description": "Maximum total passes per player before automatic forfeit (§16).",
                                  "maximum": 100,
                                  "minimum": 1,
                                  "type": "integer",
                                },
                              },
                              "required": [
                                "maxConsecutivePasses",
                                "maxTotalPassesPerPlayer",
                              ],
                              "type": "object",
                            },
                            "modeQuickStart": {
                              "description": "Reserved compatibility flag for non-standard quick-start bootstrap. Canonical v1.0-compliant matches keep this false.",
                              "type": "boolean",
                            },
                            "modeSpecialStart": {
                              "additionalProperties": false,
                              "properties": {
                                "enabled": {
                                  "description": "Enable Special Start Mode: no-attack does not count as pass until first forced reinforcement (§7).",
                                  "type": "boolean",
                                },
                                "noAttackCountsAsPassUntil": {
                                  "description": "Condition for closing the Special Start window. Default: bothPlayersCompletedFirstForcedReinforcement.",
                                  "type": "string",
                                },
                              },
                              "required": [
                                "enabled",
                              ],
                              "type": "object",
                            },
                            "rows": {
                              "description": "Number of ranks per column (§3.3). Min: 1, Max: 12. rows × columns ≤ 48.",
                              "maximum": 12,
                              "minimum": 1,
                              "type": "integer",
                            },
                            "specVersion": {
                              "enum": [
                                "1.0",
                              ],
                              "type": "string",
                            },
                          },
                          "required": [
                            "specVersion",
                            "classic",
                            "rows",
                            "columns",
                            "maxHandSize",
                            "initialDraw",
                            "modeClassicAces",
                            "modeClassicFaceCards",
                            "modeDamagePersistence",
                            "modeClassicDeployment",
                            "modeQuickStart",
                            "modeSpecialStart",
                            "initiative",
                            "modePassRules",
                          ],
                          "type": "object",
                        },
                        "players": {
                          "additionalItems": false,
                          "items": [
                            {
                              "additionalProperties": false,
                              "properties": {
                                "id": {
                                  "format": "uuid",
                                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                                  "type": "string",
                                },
                                "name": {
                                  "maxLength": 50,
                                  "minLength": 1,
                                  "type": "string",
                                },
                              },
                              "required": [
                                "id",
                                "name",
                              ],
                              "type": "object",
                            },
                            {
                              "additionalProperties": false,
                              "properties": {
                                "id": {
                                  "format": "uuid",
                                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                                  "type": "string",
                                },
                                "name": {
                                  "maxLength": 50,
                                  "minLength": 1,
                                  "type": "string",
                                },
                              },
                              "required": [
                                "id",
                                "name",
                              ],
                              "type": "object",
                            },
                          ],
                          "maxItems": 2,
                          "minItems": 2,
                          "type": "array",
                        },
                        "rngSeed": {
                          "maximum": 9007199254740991,
                          "minimum": -9007199254740991,
                          "type": "integer",
                        },
                      },
                      "required": [
                        "matchId",
                        "players",
                        "rngSeed",
                      ],
                      "type": "object",
                    },
                    "expectedSequenceNumber": {
                      "description": "Client freshness guard for rejecting stale or out-of-order actions.",
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer",
                    },
                    "msgId": {
                      "description": "Reliable transport message identifier for ACK/replay.",
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                      "type": "string",
                    },
                    "timestamp": {
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                      "type": "string",
                    },
                    "type": {
                      "enum": [
                        "system:init",
                      ],
                      "type": "string",
                    },
                  },
                  "required": [
                    "type",
                    "timestamp",
                  ],
                  "type": "object",
                },
              ],
            },
            "type": "array",
          },
          "viewerIndex": {
            "anyOf": [
              {
                "maximum": 1,
                "minimum": 0,
                "type": "integer",
              },
              {
                "type": "null",
              },
            ],
          },
        },
        "required": [
          "matchId",
          "viewerIndex",
          "preState",
          "postState",
          "action",
          "validActions",
        ],
        "type": "object",
      },
      "VictoryType": {
        "description": "Victory condition type. lpDepletion: opponent LP reaches 0. cardDepletion: opponent has no cards on battlefield or in hand. forfeit: player explicitly forfeits. passLimit: player exceeds maxConsecutivePasses or maxTotalPassesPerPlayer (§16).",
        "enum": [
          "lpDepletion",
          "cardDepletion",
          "forfeit",
          "passLimit",
        ],
        "type": "string",
      },
    },
    "securitySchemes": {
      "basicAuth": {
        "scheme": "basic",
        "type": "http",
      },
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http",
      },
      "cookieAuth": {
        "in": "cookie",
        "name": "phalanx_refresh",
        "type": "apiKey",
      },
    },
  },
  "info": {
    "description": "Authoritative game server for Phalanx Duel.

## Authoritative References

- **[RULES.md](https://github.com/phalanxduel/game/blob/main/docs/gameplay/rules.md)** — Canonical deterministic rules specification (v1.0). All game logic, state machine transitions, suit boundary effects, and victory conditions are defined here.
- **[EVENT_SCHEMAS.md](https://github.com/phalanxduel/game/blob/main/docs/api/event-schemas.md)** — External event validation schemas.
- **[AsyncAPI Spec](/docs/asyncapi.yaml)** — WebSocket protocol specification for real-time gameplay.

## Discovery Endpoints

- \`GET /api/rules/phases\` — State machine transition table. Returns all valid phase transitions and their triggers.
- \`GET /api/cards/manifest\` — Card manifest. Returns all possible cards in a standard deck with deterministic stats.
- \`GET /api/defaults\` — Default match parameters and system constraints.

## State Machine Constraints

A schema-valid action can be semantically invalid if sent in the wrong phase. The \`deploy\` action is only valid during \`DeploymentPhase\`. The \`attack\` and \`pass\` actions are only valid during \`AttackPhase\`. The \`reinforce\` action is only valid during \`ReinforcementPhase\`. The \`forfeit\` action is valid in any phase. See the \`/api/rules/phases\` endpoint for the full transition table.",
    "title": "Phalanx Duel Game Server",
    "version": "<redacted-version>",
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/admin/matches/search": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "required": true,
            "schema": {
              "minLength": 1,
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "properties": {
                      "createdAt": {
                        "type": "string",
                      },
                      "matchId": {
                        "type": "string",
                      },
                      "metadata": {
                        "type": "object",
                      },
                      "summary": {
                        "type": "string",
                      },
                    },
                    "type": "object",
                  },
                  "type": "array",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Search match summaries",
        "tags": [
          "admin",
        ],
      },
    },
    "/api/admin/players/search": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "required": true,
            "schema": {
              "minLength": 1,
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "properties": {
                      "createdAt": {
                        "type": "string",
                      },
                      "elo": {
                        "type": "integer",
                      },
                      "email": {
                        "type": "string",
                      },
                      "gamertag": {
                        "type": "string",
                      },
                      "id": {
                        "type": "string",
                      },
                      "isAdmin": {
                        "type": "boolean",
                      },
                      "suffix": {
                        "nullable": true,
                        "type": "integer",
                      },
                    },
                    "type": "object",
                  },
                  "type": "array",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Search players",
        "tags": [
          "admin",
        ],
      },
    },
    "/api/admin/stats/deep": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "suitDistribution": {
                      "items": {
                        "properties": {
                          "count": {
                            "type": "integer",
                          },
                          "suit": {
                            "nullable": true,
                            "type": "string",
                          },
                        },
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "totalMatches": {
                      "type": "integer",
                    },
                    "totalUsers": {
                      "type": "integer",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Deep system statistics",
        "tags": [
          "admin",
        ],
      },
    },
    "/api/auth/account": {
      "delete": {
        "description": "Permanently deletes the user identity and anonymizes all gameplay history.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "password": {
                    "type": "string",
                  },
                },
                "required": [
                  "password",
                ],
                "type": "object",
              },
            },
          },
          "required": true,
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "ok": {
                      "type": "boolean",
                    },
                  },
                  "required": [
                    "ok",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "security": [
          {
            "bearerAuth": [],
          },
          {
            "cookieAuth": [],
          },
        ],
        "summary": "The Purge: Permanently delete account",
        "tags": [
          "auth",
        ],
      },
    },
    "/api/auth/email": {
      "patch": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "newEmail": {
                    "format": "email",
                    "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
                    "type": "string",
                  },
                  "password": {
                    "type": "string",
                  },
                },
                "required": [
                  "newEmail",
                  "password",
                ],
                "type": "object",
              },
            },
