                            "type": "string",
                          },
                          {
                            "type": "null",
                          },
                        ],
                      },
                      "player1Name": {
                        "anyOf": [
                          {
                            "type": "string",
                          },
                          {
                            "type": "null",
                          },
                        ],
                      },
                      "player2Id": {
                        "anyOf": [
                          {
                            "type": "string",
                          },
                          {
                            "type": "null",
                          },
                        ],
                      },
                      "player2Name": {
                        "anyOf": [
                          {
                            "type": "string",
                          },
                          {
                            "type": "null",
                          },
                        ],
                      },
                      "spectatorCount": {
                        "maximum": 9007199254740991,
                        "minimum": 0,
