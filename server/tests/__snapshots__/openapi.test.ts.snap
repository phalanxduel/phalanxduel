                        "valid": {
                          "type": "boolean",
                        },
                      },
                      "type": "object",
                    },
                    "source": {
                      "enum": [
                        "memory",
                        "database",
                      ],
                      "type": "string",
                    },
                    "storedFinalHash": {
                      "type": "string",
                    },
                    "valid": {
                      "type": "boolean",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "error": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Verify match integrity",
        "tags": [
          "matches",
        ],
      },
    },
    "/api/stats": {
      "get": {
        "description": "Returns a summary of active and completed matches managed by the server.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "activeMatches": {
                      "type": "integer",
                    },
                    "completedMatches": {
                      "type": "integer",
                    },
                    "totalMatches": {
                      "type": "integer",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Global match statistics",
        "tags": [
          "stats",
        ],
      },
    },
    "/api/stats/{userId}/history": {
      "get": {
        "description": "Returns aggregated stats across all categories for a specific user.",
        "parameters": [
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "categories": {
                      "additionalProperties": {
                        "properties": {
                          "currentElo": {
                            "type": "integer",
                          },
                          "matches": {
                            "type": "integer",
                          },
                          "wins": {
                            "type": "integer",
                          },
                        },
                        "type": "object",
                      },
                      "type": "object",
                    },
                    "gamertag": {
                      "type": "string",
                    },
                    "userId": {
                      "format": "uuid",
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Get player's full history",
        "tags": [
          "stats",
        ],
      },
    },
    "/health": {
      "get": {
        "description": "Returns 200 if the process is alive. Used by orchestrators and load balancers.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "memory_heap_used_mb": {
                      "type": "integer",
                    },
                    "observability": {
                      "properties": {
                        "region": {
                          "type": "string",
                        },
                        "sentry_initialized": {
                          "type": "boolean",
                        },
                      },
                      "type": "object",
                    },
                    "status": {
                      "enum": [
                        "ok",
                      ],
                      "type": "string",
                    },
                    "timestamp": {
                      "format": "date-time",
                      "type": "string",
                    },
                    "uptime_seconds": {
                      "type": "integer",
                    },
                    "version": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Server health check (liveness probe)",
        "tags": [
          "system",
        ],
      },
    },
    "/internal/matches": {
      "post": {
        "responses": {
          "200": {
            "description": "Default Response",
          },
        },
      },
    },
    "/matches": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "properties": {
                      "ageSeconds": {
                        "type": "integer",
                      },
                      "lastActivitySeconds": {
                        "type": "integer",
                      },
                      "matchId": {
                        "format": "uuid",
                        "type": "string",
                      },
                      "phase": {
                        "nullable": true,
                        "type": "string",
                      },
                      "players": {
                        "items": {
                          "properties": {
                            "connected": {
                              "type": "boolean",
                            },
                            "name": {
                              "type": "string",
                            },
                          },
                          "type": "object",
                        },
                        "type": "array",
                      },
                      "spectatorCount": {
                        "type": "integer",
                      },
                      "turnNumber": {
                        "nullable": true,
                        "type": "integer",
                      },
                    },
                    "type": "object",
                  },
                  "type": "array",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "List all active matches",
        "tags": [
          "matches",
        ],
      },
      "post": {
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "matchId": {
                      "format": "uuid",
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Create a new match",
        "tags": [
          "matches",
        ],
      },
    },
    "/matches/completed": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": "1",
              "pattern": "^\\d+$",
              "type": "string",
            },
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": "20",
              "pattern": "^\\d+$",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "List of completed match metadata",
                  "items": {
                    "properties": {
                      "completedAt": {
                        "format": "date-time",
                        "type": "string",
                      },
                      "createdAt": {
                        "format": "date-time",
                        "type": "string",
                      },
                      "fingerprint": {
                        "nullable": true,
                        "type": "string",
                      },
                      "matchId": {
                        "format": "uuid",
                        "type": "string",
                      },
                      "playerIds": {
                        "items": {
                          "format": "uuid",
                          "nullable": true,
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "playerNames": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "turnCount": {
                        "nullable": true,
                        "type": "integer",
                      },
                      "victoryType": {
                        "nullable": true,
                        "type": "string",
                      },
                      "winnerIndex": {
                        "nullable": true,
                        "type": "integer",
                      },
                    },
                    "type": "object",
                  },
                  "type": "array",
                },
              },
            },
            "description": "List of completed match metadata",
          },
        },
        "summary": "Paginated list of completed match summaries",
        "tags": [
          "matches",
        ],
      },
    },
    "/matches/{id}/log": {
      "get": {
        "description": "Returns the full sequence of events for a match. Supports content negotiation via the format query parameter or Accept header.",
        "parameters": [
          {
            "in": "query",
            "name": "format",
            "required": false,
            "schema": {
              "default": "json",
              "enum": [
                "compact",
                "json",
              ],
              "type": "string",
            },
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Full or compact event log",
                  "oneOf": [
                    {
                      "properties": {
                        "events": {
                          "items": {
                            "additionalProperties": true,
                            "type": "object",
                          },
                          "type": "array",
                        },
                        "fingerprint": {
                          "type": "string",
                        },
                        "generatedAt": {
                          "format": "date-time",
                          "type": "string",
                        },
                        "matchId": {
                          "format": "uuid",
                          "type": "string",
                        },
                      },
                      "type": "object",
                    },
                    {
                      "items": {
                        "additionalProperties": true,
                        "type": "object",
                      },
                      "type": "array",
                    },
                  ],
                },
              },
            },
            "description": "Full or compact event log",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "error": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Event log for a match",
        "tags": [
          "matches",
        ],
      },
    },
    "/matches/{matchId}/replay": {
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "matchId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
