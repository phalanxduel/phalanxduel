                          "createdAt": {
                            "format": "date-time",
                            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                            "type": "string",
                          },
                          "createdAtIso": {
                            "format": "date-time",
                            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                            "type": "string",
                          },
                          "creatorElo": {
                            "maximum": 9007199254740991,
                            "minimum": -9007199254740991,
                            "type": "integer",
                          },
                          "creatorName": {
                            "type": "string",
                          },
                          "creatorRecord": {
                            "additionalProperties": false,
                            "properties": {
                              "confidenceLabel": {
                                "enum": [
                                  "Provisional",
                                  "Calibrating",
                                  "Established",
                                  "Inactive",
                                ],
                                "type": "string",
                              },
                              "draws": {
                                "maximum": 9007199254740991,
                                "minimum": -9007199254740991,
                                "type": "integer",
                              },
                              "gamesPlayed": {
                                "maximum": 9007199254740991,
                                "minimum": -9007199254740991,
                                "type": "integer",
                              },
                              "losses": {
                                "maximum": 9007199254740991,
                                "minimum": -9007199254740991,
                                "type": "integer",
                              },
                              "provisional": {
                                "type": "boolean",
                              },
                              "wins": {
                                "maximum": 9007199254740991,
                                "minimum": -9007199254740991,
                                "type": "integer",
                              },
                            },
                            "required": [
                              "wins",
                              "losses",
                              "draws",
                              "gamesPlayed",
                              "provisional",
                              "confidenceLabel",
                            ],
                            "type": "object",
                          },
                          "matchId": {
                            "format": "uuid",
                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                            "type": "string",
