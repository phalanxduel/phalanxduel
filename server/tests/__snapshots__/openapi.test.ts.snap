                      "type": "integer",
                    },
                    "finalStateHash": {
                      "type": "string",
                    },
                    "hashChain": {
                      "properties": {
                        "actionCount": {
                          "type": "integer",
                        },
                        "error": {
                          "nullable": true,
                          "type": "string",
                        },
                        "finalStateHash": {
                          "type": "string",
