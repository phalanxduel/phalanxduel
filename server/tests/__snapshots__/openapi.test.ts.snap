                              {
                                "type": "null",
                              },
                            ],
                          },
                        },
                        "required": [
                          "matchId",
                          "result",
                          "mode",
                          "opponentName",
                          "completedAt",
                          "turnNumber",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "record": {
                      "additionalProperties": false,
                      "properties": {
                        "draws": {
                          "maximum": 9007199254740991,
                          "minimum": -9007199254740991,
                          "type": "integer",
