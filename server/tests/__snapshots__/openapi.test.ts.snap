          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "confidenceLabel": {
                      "enum": [
                        "Provisional",
                        "Calibrating",
                        "Established",
                        "Inactive",
                      ],
                      "type": "string",
                    },
                    "displayName": {
                      "type": "string",
                    },
