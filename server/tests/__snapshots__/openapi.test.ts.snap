            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "matchId": {
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                      "type": "string",
                    },
                    "ok": {
                      "enum": [
                        true,
                      ],
                      "type": "boolean",
                    },
                    "status": {
                      "enum": [
                        "forfeited",
                      ],
                      "type": "string",
                    },
                  },
                  "required": [
                    "ok",
                    "status",
                    "matchId",
                  ],
                  "type": "object",
                },
              },
            },
