    "/api/users/{userId}/achievements": {
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "description": "All achievements earned by a player, ordered by most recent first.",
                  "properties": {
                    "achievements": {
                      "items": {
                        "additionalProperties": false,
                        "description": "A single achievement earned by a player.",
                        "properties": {
                          "awardedAt": {
                            "description": "When the achievement was awarded.",
                            "format": "date-time",
                            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                            "type": "string",
                          },
                          "id": {
                            "description": "Unique achievement record ID.",
                            "format": "uuid",
                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                            "type": "string",
                          },
                          "matchId": {
                            "anyOf": [
                              {
                                "type": "string",
                              },
                              {
                                "type": "null",
                              },
                            ],
                            "description": "Match that triggered the award, if applicable.",
                          },
                          "metadata": {
                            "additionalProperties": {},
                            "description": "Achievement-specific context data (e.g., winning LP, turn count).",
                            "type": "object",
                          },
                          "type": {
                            "description": "Achievement type identifier. Each type is awarded at most once per player.",
                            "enum": [
                              "FIRST_WIN",
                              "FIRST_MATCH",
                              "ACE_SLAYER",
                              "CLEAN_SWEEP",
                              "FULL_HOUSE",
                              "ROYAL_GUARD",
                              "DOUBLE_DOWN",
                              "LAST_STAND",
                              "IRON_WALL",
                              "HIGH_CARD",
                              "COMEBACK_KID",
                              "OPENING_GAMBIT",
                              "TEN_WINS",
                              "FIFTY_WINS",
                              "HUNDRED_WINS",
                              "DEUCE_COUP",
                              "TRIPLE_THREAT",
                              "DEAD_MANS_HAND",
                              "FLAWLESS_VICTORY",
                              "BLITZKRIEG",
                              "OVERKILL",
                            ],
                            "type": "string",
                          },
                          "userId": {
                            "description": "Player who earned this achievement.",
                            "format": "uuid",
                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                            "type": "string",
                          },
                        },
                        "required": [
                          "id",
                          "userId",
                          "type",
                          "awardedAt",
                          "matchId",
                          "metadata",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "userId": {
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                      "type": "string",
                    },
                  },
                  "required": [
                    "userId",
                    "achievements",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "All achievements earned by a player, ordered by most recent first.",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Get achievements for a user",
        "tags": [
          "profiles",
        ],
      },
    },
