        "tags": [
          "matches",
        ],
      },
    },
    "/matches/{id}/log": {
      "get": {
        "description": "Returns the full sequence of events for a match. Supports content negotiation via the format query parameter or Accept header.",
        "parameters": [
          {
            "in": "query",
            "name": "format",
            "required": false,
            "schema": {
              "default": "json",
              "enum": [
                "compact",
                "json",
              ],
              "type": "string",
            },
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Full or compact event log",
                  "oneOf": [
                    {
                      "additionalProperties": false,
                      "properties": {
                        "events": {
                          "items": {
                            "additionalProperties": false,
                            "properties": {
                              "id": {
                                "type": "string",
                              },
                              "name": {
                                "type": "string",
                              },
                              "parentId": {
                                "type": "string",
                              },
                              "payload": {
                                "additionalProperties": {},
                                "type": "object",
                              },
                              "status": {
                                "default": "ok",
                                "enum": [
                                  "ok",
                                  "unrecoverable_error",
                                ],
                                "type": "string",
                              },
                              "timestamp": {
                                "format": "date-time",
                                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                                "type": "string",
                              },
                              "type": {
                                "enum": [
                                  "span_started",
                                  "span_ended",
                                  "functional_update",
                                  "system_error",
                                ],
                                "type": "string",
                              },
                            },
                            "required": [
                              "id",
                              "type",
                              "name",
                              "timestamp",
                              "payload",
                              "status",
                            ],
                            "type": "object",
                          },
                          "type": "array",
                        },
                        "fingerprint": {
                          "type": "string",
                        },
                        "generatedAt": {
                          "format": "date-time",
                          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                          "type": "string",
                        },
                        "matchId": {
                          "format": "uuid",
                          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                          "type": "string",
                        },
                      },
                      "required": [
                        "matchId",
                        "events",
                        "fingerprint",
                        "generatedAt",
                      ],
                      "type": "object",
                    },
                    {
                      "items": {
                        "additionalProperties": true,
                        "type": "object",
                      },
                      "type": "array",
                    },
                  ],
                },
              },
            },
            "description": "Full or compact event log",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Event log for a match",
        "tags": [
          "matches",
        ],
      },
    },
    "/matches/{id}/simulate": {
      "post": {
        "description": "Executes a proposed action against the current match state and returns the resulting ViewModel. Does NOT persist any changes.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "description": "The game action to simulate",
                "properties": {
                  "playerIndex": {
                    "type": "integer",
                  },
                  "timestamp": {
                    "format": "date-time",
                    "type": "string",
                  },
                  "type": {
                    "type": "string",
                  },
                },
                "required": [
                  "type",
                ],
                "type": "object",
              },
            },
          },
          "description": "The game action to simulate",
          "required": true,
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "description": "The projected ViewModel of the state after the simulated action",
                  "properties": {
                    "action": {
                      "description": "Authoritative action payload for Phalanx: Duel.",
                      "oneOf": [
                        {
                          "additionalProperties": false,
                          "description": "Deploy a card from hand. Valid during DeploymentPhase. Each player must alternate deploying cards until the battlefield is full according to match parameters.",
                          "properties": {
                            "cardId": {
                              "description": "ID of the card to deploy from hand.",
                              "type": "string",
                            },
                            "column": {
                              "description": "Battlefield column index (0-11).",
                              "maximum": 11,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "expectedSequenceNumber": {
                              "description": "Client freshness guard for rejecting stale or out-of-order actions.",
                              "maximum": 9007199254740991,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "msgId": {
                              "description": "Reliable transport message identifier for ACK/replay.",
                              "format": "uuid",
                              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                              "type": "string",
                            },
                            "playerIndex": {
                              "description": "Index of the player (0 or 1).",
                              "maximum": 1,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "timestamp": {
                              "format": "date-time",
                              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                              "type": "string",
                            },
                            "type": {
                              "enum": [
                                "deploy",
                              ],
                              "type": "string",
                            },
                          },
                          "required": [
                            "type",
                            "playerIndex",
                            "column",
                            "cardId",
                            "timestamp",
                          ],
                          "type": "object",
                        },
                        {
                          "additionalProperties": false,
                          "description": "Declare an attack. Valid during AttackPhase. Requires a card at rank 0 of the attacking column.",
                          "properties": {
                            "attackingColumn": {
                              "description": "Column index containing the attacking card. Must have a non-null card at rank 0.",
                              "maximum": 11,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "defendingColumn": {
                              "description": "Target column index on the opponent board.",
                              "maximum": 11,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "expectedSequenceNumber": {
                              "description": "Client freshness guard for rejecting stale or out-of-order actions.",
                              "maximum": 9007199254740991,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "msgId": {
