                                            "properties": {
                                              "attackFirst": {
                                                "default": "P1",
                                                "description": "Which player attacks first in AttackPhase.",
                                                "enum": [
                                                  "P1",
                                                  "P2",
                                                ],
                                                "type": "string",
                                              },
                                              "deployFirst": {
                                                "default": "P2",
                                                "description": "Which player deploys first in DeploymentPhase.",
                                                "enum": [
                                                  "P1",
                                                  "P2",
                                                ],
                                                "type": "string",
                                              },
                                            },
                                            "required": [
                                              "deployFirst",
                                              "attackFirst",
                                            ],
                                            "type": "object",
                                          },
                                          "mode": {
                                            "default": "strict",
                                            "description": "Classic schema binding mode (§3.1). strict: all top-level parameters must exactly match the classic template. hybrid: classic values serve as defaults, top-level may override within Global System Constraints.",
                                            "enum": [
                                              "strict",
                                              "hybrid",
                                            ],
                                            "type": "string",
                                          },
                                          "modes": {
                                            "additionalProperties": false,
                                            "properties": {
                                              "classicAces": {
                                                "default": true,
                                                "description": "Enable Classic Ace rules: Aces only destroyed by other Aces at rank 0 (§10).",
                                                "type": "boolean",
                                              },
                                              "classicFaceCards": {
                                                "default": true,
                                                "description": "Enable Classic Face Card rules: J→J, Q→J/Q, K→J/Q/K destruction hierarchy (§11).",
                                                "type": "boolean",
                                              },
                                              "damagePersistence": {
                                                "default": "classic",
                                                "description": "Damage mode. classic: no HP persists between turns. cumulative: damage persists (§12).",
                                                "enum": [
                                                  "classic",
                                                  "cumulative",
                                                ],
                                                "type": "string",
                                              },
                                              "quickStart": {
                                                "default": false,
                                                "description": "Reserved compatibility flag. Must be false for v1.0-compliant matches (§3.4).",
                                                "type": "boolean",
                                              },
                                            },
                                            "required": [
                                              "classicAces",
                                              "classicFaceCards",
                                              "damagePersistence",
                                              "quickStart",
                                            ],
                                            "type": "object",
                                          },
                                          "passRules": {
                                            "additionalProperties": false,
                                            "properties": {
                                              "maxConsecutivePasses": {
                                                "default": 3,
                                                "description": "Maximum consecutive passes before automatic forfeit (§16). Default: 3.",
                                                "maximum": 100,
                                                "minimum": 1,
                                                "type": "integer",
                                              },
                                              "maxTotalPassesPerPlayer": {
                                                "default": 5,
                                                "description": "Maximum total passes per player before automatic forfeit (§16). Default: 5.",
                                                "maximum": 100,
                                                "minimum": 1,
                                                "type": "integer",
                                              },
                                            },
                                            "required": [
                                              "maxConsecutivePasses",
                                              "maxTotalPassesPerPlayer",
                                            ],
                                            "type": "object",
                                          },
                                          "start": {
                                            "additionalProperties": false,
                                            "properties": {
                                              "initialDraw": {
                                                "default": 12,
                                                "description": "Cards drawn at match start. Formula: rows × columns + columns (§3.3). Default: 12.",
                                                "maximum": 60,
                                                "minimum": 1,
                                                "type": "integer",
                                              },
                                            },
                                            "required": [
                                              "initialDraw",
                                            ],
                                            "type": "object",
                                          },
                                        },
                                        "required": [
                                          "enabled",
                                          "mode",
                                          "battlefield",
                                          "hand",
                                          "start",
                                          "modes",
                                          "initiative",
                                          "passRules",
                                        ],
                                        "type": "object",
                                      },
                                      "columns": {
                                        "description": "Number of columns per player board (§3.3). Min: 1, Max: 12. rows × columns ≤ 48.",
                                        "maximum": 12,
                                        "minimum": 1,
                                        "type": "integer",
                                      },
                                      "initialDraw": {
                                        "description": "Cards drawn at match start. Must equal rows × columns + columns (§3.3).",
                                        "maximum": 60,
                                        "minimum": 1,
                                        "type": "integer",
                                      },
                                      "initiative": {
                                        "additionalProperties": false,
                                        "properties": {
                                          "attackFirst": {
                                            "description": "Which player attacks first in AttackPhase.",
                                            "enum": [
                                              "P1",
                                              "P2",
                                            ],
                                            "type": "string",
                                          },
                                          "deployFirst": {
                                            "description": "Which player deploys first in DeploymentPhase.",
                                            "enum": [
                                              "P1",
                                              "P2",
                                            ],
                                            "type": "string",
                                          },
                                        },
                                        "required": [
                                          "deployFirst",
                                          "attackFirst",
                                        ],
                                        "type": "object",
                                      },
                                      "maxHandSize": {
                                        "description": "Maximum hand size. Must be ≤ columns (§3.3).",
                                        "maximum": 12,
                                        "minimum": 0,
                                        "type": "integer",
                                      },
                                      "modeClassicAces": {
                                        "description": "Enable Classic Ace invulnerability rules (§10).",
                                        "type": "boolean",
                                      },
                                      "modeClassicDeployment": {
                                        "description": "Enable Classic Deployment: alternating card placement (§5).",
                                        "type": "boolean",
                                      },
                                      "modeClassicFaceCards": {
                                        "description": "Enable Classic Face Card destruction hierarchy (§11).",
                                        "type": "boolean",
                                      },
                                      "modeDamagePersistence": {
                                        "description": "Damage persistence mode (§12).",
                                        "enum": [
                                          "classic",
                                          "cumulative",
                                        ],
                                        "type": "string",
                                      },
                                      "modePassRules": {
                                        "additionalProperties": false,
                                        "properties": {
                                          "maxConsecutivePasses": {
                                            "description": "Maximum consecutive passes before automatic forfeit (§16).",
                                            "maximum": 100,
                                            "minimum": 1,
                                            "type": "integer",
                                          },
                                          "maxTotalPassesPerPlayer": {
                                            "description": "Maximum total passes per player before automatic forfeit (§16).",
                                            "maximum": 100,
                                            "minimum": 1,
                                            "type": "integer",
                                          },
                                        },
                                        "required": [
                                          "maxConsecutivePasses",
                                          "maxTotalPassesPerPlayer",
                                        ],
                                        "type": "object",
                                      },
                                      "modeQuickStart": {
                                        "description": "Reserved compatibility flag for non-standard quick-start bootstrap. Canonical v1.0-compliant matches keep this false.",
                                        "type": "boolean",
                                      },
                                      "modeSpecialStart": {
                                        "additionalProperties": false,
                                        "properties": {
                                          "enabled": {
                                            "description": "Enable Special Start Mode: no-attack does not count as pass until first forced reinforcement (§7).",
                                            "type": "boolean",
                                          },
                                          "noAttackCountsAsPassUntil": {
                                            "description": "Condition for closing the Special Start window. Default: bothPlayersCompletedFirstForcedReinforcement.",
                                            "type": "string",
                                          },
                                        },
                                        "required": [
                                          "enabled",
                                        ],
                                        "type": "object",
                                      },
                                      "rows": {
                                        "description": "Number of ranks per column (§3.3). Min: 1, Max: 12. rows × columns ≤ 48.",
                                        "maximum": 12,
                                        "minimum": 1,
                                        "type": "integer",
                                      },
                                      "specVersion": {
                                        "enum": [
                                          "1.0",
                                        ],
                                        "type": "string",
                                      },
                                    },
                                    "required": [
                                      "specVersion",
                                      "classic",
                                      "rows",
                                      "columns",
                                      "maxHandSize",
                                      "initialDraw",
                                      "modeClassicAces",
                                      "modeClassicFaceCards",
                                      "modeDamagePersistence",
                                      "modeClassicDeployment",
                                      "modeQuickStart",
                                      "modeSpecialStart",
                                      "initiative",
                                      "modePassRules",
                                    ],
                                    "type": "object",
                                  },
                                  "players": {
                                    "additionalItems": false,
                                    "items": [
                                      {
                                        "additionalProperties": false,
                                        "properties": {
                                          "id": {
                                            "format": "uuid",
                                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                                            "type": "string",
                                          },
                                          "name": {
                                            "maxLength": 50,
                                            "minLength": 1,
                                            "type": "string",
                                          },
                                        },
                                        "required": [
                                          "id",
                                          "name",
                                        ],
                                        "type": "object",
                                      },
                                      {
                                        "additionalProperties": false,
                                        "properties": {
                                          "id": {
                                            "format": "uuid",
                                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                                            "type": "string",
                                          },
                                          "name": {
                                            "maxLength": 50,
                                            "minLength": 1,
                                            "type": "string",
                                          },
                                        },
                                        "required": [
                                          "id",
                                          "name",
                                        ],
                                        "type": "object",
                                      },
                                    ],
                                    "maxItems": 2,
                                    "minItems": 2,
                                    "type": "array",
                                  },
                                  "rngSeed": {
                                    "maximum": 9007199254740991,
                                    "minimum": -9007199254740991,
                                    "type": "integer",
                                  },
                                },
                                "required": [
                                  "matchId",
                                  "players",
                                  "rngSeed",
                                ],
                                "type": "object",
                              },
                              "expectedSequenceNumber": {
                                "description": "Client freshness guard for rejecting stale or out-of-order actions.",
                                "maximum": 9007199254740991,
                                "minimum": 0,
                                "type": "integer",
                              },
                              "msgId": {
                                "description": "Reliable transport message identifier for ACK/replay.",
                                "format": "uuid",
                                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                                "type": "string",
                              },
                              "timestamp": {
                                "format": "date-time",
                                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                                "type": "string",
                              },
                              "type": {
                                "enum": [
                                  "system:init",
                                ],
                                "type": "string",
                              },
                            },
                            "required": [
                              "type",
                              "timestamp",
                            ],
                            "type": "object",
                          },
                        ],
                      },
                      "type": "array",
                    },
                    "viewerIndex": {
                      "anyOf": [
                        {
                          "maximum": 1,
                          "minimum": 0,
                          "type": "integer",
                        },
                        {
                          "type": "null",
                        },
                      ],
                    },
                  },
                  "required": [
                    "matchId",
                    "viewerIndex",
                    "preState",
                    "postState",
                    "action",
                    "validActions",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "The redacted turn result for the acting player",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Submit a game action over REST",
        "tags": [
          "matches",
        ],
      },
    },
    "/api/matches/{id}/actions": {
      "get": {
        "description": "Returns the ordered public action log for a completed match. No authentication is required for completed matches.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Replayable completed-match action log",
                  "properties": {
                    "actions": {
                      "items": {
                        "properties": {
                          "playerIndex": {
                            "type": "integer",
                          },
                          "sequenceNumber": {
                            "type": "integer",
                          },
                          "stateHashAfter": {
                            "type": "string",
                          },
                          "stateHashBefore": {
                            "type": "string",
                          },
                          "timestamp": {
                            "format": "date-time",
                            "type": "string",
                          },
                          "type": {
                            "type": "string",
                          },
                        },
                        "required": [
                          "sequenceNumber",
                          "type",
                          "playerIndex",
                          "timestamp",
                          "stateHashBefore",
                          "stateHashAfter",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "engineVersion": {
                      "type": "string",
                    },
                    "matchId": {
                      "format": "uuid",
                      "type": "string",
                    },
                    "player1Name": {
                      "type": "string",
                    },
                    "player2Name": {
                      "type": "string",
                    },
                    "seed": {
                      "type": "integer",
                    },
                    "startingLifepoints": {
                      "type": "integer",
                    },
                    "totalActions": {
                      "type": "integer",
                    },
                  },
                  "required": [
                    "matchId",
                    "engineVersion",
                    "seed",
                    "startingLifepoints",
                    "player1Name",
                    "player2Name",
                    "totalActions",
                    "actions",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Replayable completed-match action log",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Completed match action log",
        "tags": [
          "matches",
        ],
      },
    },
    "/api/matches/{id}/join": {
      "post": {
        "description": "Allocates a player seat and returns the player secret needed for subsequent WebSocket rejoin or action authorization.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "playerName": {
                    "maxLength": 50,
                    "minLength": 1,
                    "type": "string",
                  },
                  "userId": {
                    "format": "uuid",
                    "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                    "type": "string",
                  },
                },
                "required": [
                  "playerName",
                ],
                "type": "object",
              },
            },
          },
          "required": true,
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "description": "Assigned player seat details",
                  "properties": {
                    "matchId": {
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                      "type": "string",
                    },
                    "playerId": {
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                      "type": "string",
                    },
                    "playerIndex": {
                      "maximum": 1,
                      "minimum": 0,
                      "type": "integer",
                    },
                    "role": {
                      "enum": [
                        "P0",
                        "P1",
                      ],
                      "type": "string",
                    },
                  },
                  "required": [
                    "matchId",
                    "playerId",
                    "playerIndex",
                    "role",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Assigned player seat details",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string",
                    },
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "code",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "summary": "Join a match without WebSocket bootstrap",
        "tags": [
          "matches",
        ],
      },
    },
    "/api/matches/{id}/replay": {
      "get": {
        "description": "Replays a completed match from the deterministic initial state through the first N public actions and returns the resulting GameState.",
        "parameters": [
          {
            "in": "query",
            "name": "step",
            "required": false,
            "schema": {
              "default": "0",
              "pattern": "^\\d+$",
              "type": "string",
            },
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "description": "Game state at the requested replay step",
                  "properties": {
                    "activePlayerIndex": {
                      "description": "Index of the player whose turn it is (0 or 1).",
                      "maximum": 1,
                      "minimum": 0,
                      "type": "integer",
                    },
                    "gameOptions": {
                      "additionalProperties": false,
                      "description": "Runtime compatibility inputs applied at match creation. These fields are transport-facing and do not supersede the canonical match params contract.",
                      "properties": {
                        "classicDeployment": {
                          "default": true,
                          "description": "Compatibility-only runtime override for deployment bootstrap. Canonical v1.0 rule authority belongs to \`modeClassicDeployment\` in the match params.",
                          "type": "boolean",
                        },
                        "damageMode": {
                          "default": "classic",
                          "description": "Compatibility-only runtime override. Canonical v1.0 rule authority belongs to match params \`modeDamagePersistence\`, not \`gameOptions.damageMode\`.",
                          "enum": [
                            "classic",
                            "cumulative",
                          ],
                          "type": "string",
                        },
                        "quickStart": {
                          "description": "Compatibility-only bootstrap shortcut. If true, runtime may skip deployment and pre-fill the battlefield, but canonical v1.0-compliant matches keep this disabled.",
                          "type": "boolean",
                        },
                        "startingLifepoints": {
                          "default": 20,
                          "description": "Compatibility-only runtime override for bootstrap surfaces. Canonical v1.0 gameplay is defined by the match params contract, not \`gameOptions.startingLifepoints\`.",
                          "maximum": 500,
                          "minimum": 1,
                          "type": "integer",
                        },
                      },
                      "required": [
                        "damageMode",
                        "startingLifepoints",
                        "classicDeployment",
                      ],
                      "type": "object",
                    },
                    "matchId": {
                      "description": "Unique match identifier (UUID v4).",
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                      "type": "string",
                    },
                    "outcome": {
                      "anyOf": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "turnNumber": {
                              "description": "Turn number when victory was achieved.",
                              "maximum": 9007199254740991,
                              "minimum": 0,
                              "type": "integer",
                            },
                            "victoryType": {
                              "description": "Victory condition type. lpDepletion: opponent LP reaches 0. cardDepletion: opponent has no cards on battlefield or in hand. forfeit: player explicitly forfeits. passLimit: player exceeds maxConsecutivePasses or maxTotalPassesPerPlayer (§16).",
                              "enum": [
                                "lpDepletion",
                                "cardDepletion",
                                "forfeit",
                                "passLimit",
                              ],
                              "type": "string",
                            },
                            "winnerIndex": {
                              "description": "Index of the winning player (0 or 1).",
                              "maximum": 1,
                              "minimum": 0,
                              "type": "integer",
                            },
                          },
                          "required": [
                            "winnerIndex",
                            "victoryType",
                            "turnNumber",
                          ],
                          "type": "object",
                        },
                        {
                          "type": "null",
                        },
                      ],
                      "description": "Match outcome. Present only when phase is gameOver.",
