                            "minimum": 1,
                            "type": "integer",
                          },
                          "rows": {
                            "default": 2,
                            "description": "Number of ranks (rows) per column. Default: 2. Max: 12 (§3.3).",
                            "maximum": 12,
                            "minimum": 1,
                            "type": "integer",
                          },
                        },
                        "required": [
                          "rows",
                          "columns",
                        ],
                        "type": "object",
                      },
