{
  "name": "@phalanxduel/shared",
  "version": "0.5.0-rev.3",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hash": {
      "import": "./dist/hash.js",
      "default": "./dist/hash.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
