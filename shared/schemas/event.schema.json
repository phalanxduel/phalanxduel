{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "parentId": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "span_started",
        "span_ended",
        "functional_update",
        "system_error"
      ]
    },
    "name": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "payload": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "status": {
      "default": "ok",
      "type": "string",
      "enum": [
        "ok",
        "unrecoverable_error"
      ]
    }
  },
  "required": [
    "id",
    "type",
    "name",
    "timestamp",
    "payload",
    "status"
  ],
  "additionalProperties": false
}
