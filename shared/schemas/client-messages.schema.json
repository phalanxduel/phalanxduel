{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "createMatch"
        },
        "playerName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Name of the player creating the match."
        },
        "gameOptions": {
          "description": "Optional overrides for game logic.",
          "type": "object",
          "properties": {
            "damageMode": {
              "default": "classic",
              "type": "string",
              "enum": [
                "classic",
                "cumulative"
              ],
              "description": "Damage persistence mode (§12). classic: card HP resets each turn. cumulative: damage persists across turns."
            },
            "startingLifepoints": {
              "default": 20,
              "description": "Starting life points per player. Default: 20. Range: 1-500.",
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            },
            "classicDeployment": {
              "default": true,
              "description": "Enable Classic Deployment Mode: alternating card placement until battlefield full (§5).",
              "type": "boolean"
            },
            "quickStart": {
              "description": "If true, skip deployment and start with a pre-filled battlefield.",
              "type": "boolean"
            }
          },
          "required": [
            "damageMode",
            "startingLifepoints",
            "classicDeployment"
          ],
          "additionalProperties": false
        },
        "rngSeed": {
          "description": "Fixed seed for deterministic deck shuffling.",
          "type": "number"
        },
        "opponent": {
          "description": "Type of opponent to match against.",
          "type": "string",
          "enum": [
            "human",
            "bot-random",
            "bot-heuristic"
          ]
        },
        "matchParams": {
          "description": "Authoritative match configuration parameters.",
          "type": "object",
          "properties": {
            "rows": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12,
              "description": "Number of ranks per column (§3.3). Min: 1, Max: 12. rows × columns ≤ 48."
            },
            "columns": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12,
              "description": "Number of columns per player board (§3.3). Min: 1, Max: 12. rows × columns ≤ 48."
            },
            "maxHandSize": {
              "type": "integer",
              "minimum": 0,
              "maximum": 12,
              "description": "Maximum hand size. Must be ≤ columns (§3.3)."
            },
            "initialDraw": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "description": "Cards drawn at match start. Must equal rows × columns + columns (§3.3)."
            }
          },
          "additionalProperties": false
        },
        "msgId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "Unique transport message identifier used for ACK/replay."
        },
        "telemetry": {
          "type": "object",
          "properties": {
            "traceparent": {
              "description": "Optional W3C traceparent header propagated through the WebSocket message.",
              "type": "string"
            },
            "tracestate": {
              "description": "Optional W3C tracestate header propagated through the WebSocket message.",
              "type": "string"
            },
            "baggage": {
              "description": "Optional W3C baggage header propagated through the WebSocket message.",
              "type": "string"
            },
            "qaRunId": {
              "description": "Optional QA run identifier used to correlate simulator-driven traffic.",
              "type": "string"
            },
            "sessionId": {
              "description": "Optional WebSocket session identifier used to distinguish reconnect cycles.",
              "type": "string"
            },
            "reconnectAttempt": {
              "description": "Optional reconnect attempt counter for the current WebSocket session.",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "originService": {
              "description": "Optional source service name that emitted the WebSocket message.",
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "Optional telemetry envelope for propagating trace context over WebSocket messages."
        }
      },
      "required": [
        "type",
        "playerName",
        "msgId"
      ],
      "additionalProperties": false,
      "description": "Request to create a new match. Reliable client message; requires msgId."
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "joinMatch"
        },
        "matchId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "UUID of the match to join."
        },
        "playerName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Name of the player joining."
        },
        "msgId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "Unique transport message identifier used for ACK/replay."
        },
        "telemetry": {
          "type": "object",
          "properties": {
            "traceparent": {
              "description": "Optional W3C traceparent header propagated through the WebSocket message.",
              "type": "string"
            },
            "tracestate": {
              "description": "Optional W3C tracestate header propagated through the WebSocket message.",
              "type": "string"
            },
            "baggage": {
              "description": "Optional W3C baggage header propagated through the WebSocket message.",
              "type": "string"
            },
            "qaRunId": {
              "description": "Optional QA run identifier used to correlate simulator-driven traffic.",
              "type": "string"
            },
            "sessionId": {
              "description": "Optional WebSocket session identifier used to distinguish reconnect cycles.",
              "type": "string"
            },
            "reconnectAttempt": {
              "description": "Optional reconnect attempt counter for the current WebSocket session.",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "originService": {
              "description": "Optional source service name that emitted the WebSocket message.",
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "Optional telemetry envelope for propagating trace context over WebSocket messages."
        }
      },
      "required": [
        "type",
        "matchId",
        "playerName",
        "msgId"
      ],
      "additionalProperties": false,
      "description": "Request to join an existing match as the second player. Reliable client message; requires msgId."
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "rejoinMatch"
        },
        "matchId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "UUID of the match to rejoin."
        },
        "playerId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "Player secret ID obtained during initial join/creation."
        },
        "msgId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "Unique transport message identifier used for ACK/replay."
        },
        "telemetry": {
          "type": "object",
          "properties": {
            "traceparent": {
              "description": "Optional W3C traceparent header propagated through the WebSocket message.",
              "type": "string"
            },
            "tracestate": {
              "description": "Optional W3C tracestate header propagated through the WebSocket message.",
              "type": "string"
            },
            "baggage": {
              "description": "Optional W3C baggage header propagated through the WebSocket message.",
              "type": "string"
            },
            "qaRunId": {
              "description": "Optional QA run identifier used to correlate simulator-driven traffic.",
              "type": "string"
            },
            "sessionId": {
              "description": "Optional WebSocket session identifier used to distinguish reconnect cycles.",
              "type": "string"
            },
            "reconnectAttempt": {
              "description": "Optional reconnect attempt counter for the current WebSocket session.",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "originService": {
              "description": "Optional source service name that emitted the WebSocket message.",
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "Optional telemetry envelope for propagating trace context over WebSocket messages."
        }
      },
      "required": [
        "type",
        "matchId",
        "playerId",
        "msgId"
      ],
      "additionalProperties": false,
      "description": "Re-establish connection to an active match. Reliable client message; requires msgId."
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
