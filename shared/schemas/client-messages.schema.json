    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "action"
        },
        "matchId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "description": "UUID of the match."
        },
        "action": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "deploy"
                },
                "playerIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Index of the player (0 or 1)."
                },
                "column": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 11,
                  "description": "Battlefield column index (0-11)."
                },
                "cardId": {
                  "type": "string",
                  "description": "ID of the card to deploy from hand."
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                }
              },
              "required": [
                "type",
                "playerIndex",
                "column",
                "cardId",
                "timestamp"
              ],
              "additionalProperties": false,
              "description": "Deploy a card from hand. Valid during DeploymentPhase. Each player must alternate deploying cards until the battlefield is full according to match parameters."
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "attack"
                },
                "playerIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Index of the player (0 or 1)."
                },
                "attackingColumn": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 11,
                  "description": "Column index containing the attacking card. Must have a non-null card at rank 0."
                },
                "defendingColumn": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 11,
                  "description": "Target column index on the opponent board."
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                }
              },
              "required": [
                "type",
                "playerIndex",
                "attackingColumn",
                "defendingColumn",
                "timestamp"
              ],
              "additionalProperties": false,
              "description": "Declare an attack. Valid during AttackPhase. Requires a card at rank 0 of the attacking column."
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "pass"
                },
                "playerIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Index of the player (0 or 1)."
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                }
              },
              "required": [
                "type",
                "playerIndex",
                "timestamp"
              ],
              "additionalProperties": false,
              "description": "Pass the current turn. Valid during AttackPhase. Excessive consecutive or total passes will result in a forfeit."
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "reinforce"
                },
                "playerIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Index of the player (0 or 1)."
                },
                "cardId": {
                  "type": "string",
                  "description": "ID of the card to deploy from hand."
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                }
              },
              "required": [
                "type",
                "playerIndex",
                "cardId",
                "timestamp"
              ],
              "additionalProperties": false,
              "description": "Reinforce a column after cleanup. Valid during ReinforcementPhase. Cards are deployed to the back-most empty rank of the column."
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "forfeit"
                },
                "playerIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Index of the player (0 or 1)."
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                }
              },
              "required": [
                "type",
                "playerIndex",
                "timestamp"
              ],
              "additionalProperties": false,
              "description": "Immediately forfeit the match. Valid in any phase."
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "system:init"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                }
              },
              "required": [
                "type",
                "timestamp"
              ],
              "additionalProperties": false,
              "description": "Internal: Initialize match state."
            }
          ],
          "description": "Authoritative action payload for Phalanx: Duel."
        },
        "msgId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
