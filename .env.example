# ── Required ──────────────────────────────────────────────────────────
# Used by all profiles. Docker Compose provides a default for dev/staging.
DATABASE_URL=

# Required for production profile (compose will error if unset).
# Dev/staging default to 'phalanx-dev-secret'.
JWT_SECRET=

# ── App Configuration ─────────────────────────────────────────────────
# PHALANX_SERVER_PORT=3001
# PHALANX_ADMIN_PORT=3002
# LOG_LEVEL=debug               # dev default; staging/production use 'info'
# PHALANX_ADMIN_USER=phalanx    # Basic Auth for /admin (dev default: phalanx)
# PHALANX_ADMIN_PASSWORD=phalanx

# ── Admin Console (dev profile) ─────────────────────────────────────
# Shared token for game server ↔ admin internal API.
# Docker Compose dev profile defaults to 'phalanx-dev-admin-token'.
# ADMIN_INTERNAL_TOKEN=

# ── OpenTelemetry (Local Collector) ──────────────────────────────────
# Point to local OTel collector (OTLP/HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT="http://127.0.0.1:4318"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_SERVICE_NAME="phx-server"

# ── OpenTelemetry / Observability ───────────────────────────────────
# Dev profile: Grafana LGTM all-in-one (Tempo + Loki + Prometheus + Grafana)
#   http://127.0.0.1:3000 — Grafana UI (admin/admin)
#   Traces, logs, and metrics are pre-configured with cross-linking.
#
# Staging/production: Standalone OTel Collector (otel-collector-config.yaml)
LGTM_OTLP_ENDPOINT=127.0.0.1:4317

# ── Docker Compose Profiles ──────────────────────────────────────────
# Start with one of:
#   docker compose --profile dev up --build
#   docker compose --profile staging up --build
#   docker compose --profile production up --build
#
# Run tests inside dev container (unset DATABASE_URL for unit test mode):
#   docker compose --profile dev run --rm -e DATABASE_URL= app-dev pnpm -r test
#
# Or use pnpm shortcuts:
#   pnpm docker:up        # Build and start (game + admin + Postgres + OTel)
#   pnpm docker:down      # Stop and wipe volumes
#   pnpm docker:rebuild   # Nuke and rebuild from scratch
#   pnpm docker:test      # Run tests inside container
#   pnpm docker:logs      # Tail game server logs
#
# Ports (dev profile):
#   127.0.0.1:3000  — Grafana (traces, logs, metrics — admin/admin)
#   127.0.0.1:3001  — Game server (HTTP + WebSocket)
#   127.0.0.1:3002  — Admin console
#   127.0.0.1:9229  — Node.js inspector (chrome://inspect or VS Code attach)
#   127.0.0.1:5432  — PostgreSQL
