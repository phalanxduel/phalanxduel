# Phalanx Duel - Environment Template
# Copy this to .env.local (for dev) or .env.production.local (for prod)

# Required for App Startup
DATABASE_URL=

# Required for Deployment / Sentry
# OpenTelemetry Collector Configuration
# --------------------------------------------------
# Primary exporter to use (otlphttp/sentry or otlp/signoz)
OTEL_COLLECTOR_PRIMARY_EXPORTER=otlp/signoz

# Sentry OTLP Settings (Used in Staging/Production)
SENTRY_OTLP_TRACES_ENDPOINT=https://o4510916664557568.ingest.us.sentry.io/api/4511063590240256/integration/otlp/v1/traces
SENTRY_OTLP_LOGS_ENDPOINT=https://o4510916664557568.ingest.us.sentry.io/api/4511063590240256/integration/otlp/v1/logs
SENTRY_OTLP_AUTH_HEADER="sentry sentry_key=0c43289da6ecd226aff5b1d973a20957"

# SigNoz / Local Settings (Used in Development)
SIGNOZ_OTLP_ENDPOINT=localhost:4317
SIGNOZ_INSECURE=true
SIGNOZ_ACCESS_TOKEN=

# Sentry Legacy SDK Settings (Optional)
SENTRY_AUTH_TOKEN=
SENTRY__SERVER__SENTRY_DSN=
SENTRY__CLIENT__SENTRY_DSN=
SENTRY__ADMIN__SENTRY_DSN=
VITE_SENTRY__CLIENT__SENTRY_DSN=
VITE_SENTRY__ADMIN__SENTRY_DSN=
PHALANX_ENABLE_LOCAL_SENTRY=0

# Optional Overrides
# PHALANX_SERVER_PORT=3001
# PHALANX_ADMIN_PORT=3002
