{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,mjs}", "bin/*.{zsh,sh}"],
      "project": ["scripts/**/*.{ts,mjs}"]
    },
    "shared": {
      "entry": ["src/index.ts", "src/hash.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "engine": {
      "entry": "src/index.ts",
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "server": {
      "entry": "src/index.ts",
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "client": {
      "entry": "src/main.ts",
      "project": ["src/**/*.{ts,css}"]
    }
  },
  "ignore": ["**/*.d.ts", "**/*.snap", "logs/**", "**/dist/**", "coverage/**"],
  "ignoreBinaries": ["zsh", "bin/qa/bootstrap.zsh"],
  "ignoreDependencies": [
    "playwright",
    "dependency-cruiser",
    "pino-pretty",
    "@openapitools/openapi-generator-cli"
  ],
  "ignoreExportsUsedInFile": true
}
