{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,mjs}"],
      "project": ["scripts/**/*.{ts,mjs}"]
    },
    "shared": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "engine": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "server": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "client": {
      "project": ["src/**/*.ts"]
    },
    "admin": {
      "project": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts"]
    },
    "mcp": {
      "entry": ["src/server.ts", "demo-llama.ts"],
      "project": ["src/**/*.ts", "demo-llama.ts"]
    }
  },
  "ignore": [
    "**/.stryker-tmp/**",
    ".artifacts/**",
    "artifacts/**",
    "engine/reports/**",
    "playwright-report/**",
    "reports/**",
    "test-results/**"
  ],
  "ignoreBinaries": [
    "bin/qa/bootstrap.zsh",
    "bin/dock",
    "bin/maint/fix",
    "go",
    "k6",
    "psql",
    "pg_dump",
    "diff",
    "flyctl",
    "gh",
    "fly",
    "docker-compose"
  ],
  "ignoreDependencies": [
    "dependency-cruiser",
    "pino-pretty",
    "@openapitools/openapi-generator-cli",
    "undici"
  ],
  "ignoreExportsUsedInFile": true
}
