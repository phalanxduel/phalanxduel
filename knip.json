{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,mjs}"],
      "project": ["scripts/**/*.{ts,mjs}"]
    },
    "shared": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "engine": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "server": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "client": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreBinaries": [
    "bin/qa/bootstrap.zsh",
    "bin/dock",
    "bin/maint/fix",
    "go",
    "psql",
    "pg_dump",
    "diff",
    "flyctl",
    "gh",
    "fly"
  ],
  "ignoreDependencies": [
    "dependency-cruiser",
    "pino-pretty",
    "@openapitools/openapi-generator-cli"
  ],
  "ignoreExportsUsedInFile": true
}
